const pool = require("../../db");
const { v4: uuidv4 } = require("uuid");

const coreBankingClient = require("../utils/coreBankingClient");
const ENDPOINTS = require("../utils/coreEndpoints");

// ✅ Read directly from ENV
const INSTITUTION_CODE = process.env.MFB_CODE;

if (!INSTITUTION_CODE) {
  console.warn("⚠️ MFB_CODE is not set in environment variables");
}
class LoanService {

  static normalizeName(name) {
  return name
    .toLowerCase()
    .replace(/[^a-z\s]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}
static isNameMatch(bvnFullName, accountName) {
  const cleanBVN = LoanService.normalizeName(bvnFullName);
  const cleanAccount = LoanService.normalizeName(accountName);

  // Strict full match
  if (cleanBVN === cleanAccount) return true;

  // Token match (safer fallback)
  const bvnParts = cleanBVN.split(" ");
  return bvnParts.every(part => cleanAccount.includes(part));
}

  /* ==================================================
   CENTRALIZED LOAN SETTINGS LOADER
================================================== */
static async getLoanSettings(client = null) {
  const db = client || pool;

  const res = await db.query(
    `SELECT loan_settings FROM system_settings LIMIT 1`
  );

  if (!res.rows.length) {
    throw new Error("Loan settings not found");
  }

  return res.rows[0].loan_settings || {};
}

  /**
   * ==================================================
   * PUBLIC LOAN SUBMISSION (INTERNAL ONLY)
   * ==================================================
   */
  static async createLoanApplication(payload) {
const client = await pool.connect();

try {
await client.query("BEGIN");
  const {
    loanSessionId,
    crmStaffId,
    productCode,
    dynamic = {},
  } = payload;

  /* ================= VALIDATE SESSION ================= */
  const sessionRes = await client.query(
    `
    SELECT id, bvn_verified_at, nin_verified_at
    FROM loan_sessions
    WHERE id = $1
    `,
    [loanSessionId]
  );

  if (!sessionRes.rows.length) {
    throw new Error("Invalid loan session");
  }

  const session = sessionRes.rows[0];

  
if (!session) {
  throw new Error("Customer verification incomplete");
}

  /* ================= PREVENT DUPLICATES ================= */
  const existingLoan = await client.query(
  `SELECT id FROM loans WHERE session_id = $1 FOR UPDATE`,
  [loanSessionId]
);

  if (existingLoan.rows.length) {
    throw new Error("Loan already submitted for this session");
  }

  /* ================= LOAD LOAN SETTINGS ================= */
  const loanConfig = await LoanService.getLoanSettings();

  const default_account_officer_id =
    loanConfig.defaultAccountOfficerId || null;

  /* ================= PRODUCT VALIDATION ================= */
  if (!productCode) {
    throw new Error("Loan product code missing");
  }

  const productMeta =
    loanConfig.productMeta?.[productCode];

  if (!productMeta) {
    throw new Error(`Loan product ${productCode} not configured`);
  }

  console.log("📦 Dynamic payload received:", dynamic);

  /* ================= SALARY ACCOUNT DETECTION ================= */
  /* ================= SALARY ACCOUNT DETECTION ================= */

// 1️⃣ Try strict known key first
let salaryAccountNumber =
  dynamic.field_account_number ||
  dynamic.salary_account_number ||
  dynamic.account_number ||
  null;

// 2️⃣ Fallback: try fuzzy detection
if (!salaryAccountNumber) {
  const detectedKey = Object.keys(dynamic).find(key =>
    key.toLowerCase().includes("account")
  );

  if (detectedKey) {
    salaryAccountNumber = String(dynamic[detectedKey]).trim();
  }
}

if (!salaryAccountNumber) {
  throw new Error("Salary account number is required");
}

if (!/^\d{10,11}$/.test(salaryAccountNumber)) {
  throw new Error("Invalid salary account number format");
}

console.log("Detected salary account:", salaryAccountNumber);

  /* ================= LOAN AMOUNT VALIDATION ================= */
  const amountField = Object.keys(dynamic).find(
    key => key.toLowerCase().includes("amount")
  );

  const loanAmount = Number(dynamic[amountField] || 0);

  console.log("Detected amount field:", amountField);
  console.log("Parsed loan amount:", loanAmount);

  if (!loanAmount || loanAmount <= 0) {
    throw new Error("Invalid loan amount");
  }

  if (
    productMeta.minAmount &&
    loanAmount < Number(productMeta.minAmount)
  ) {
    throw new Error(
      `Minimum allowed amount is ₦${Number(
        productMeta.minAmount
      ).toLocaleString()}`
    );
  }

  if (
    productMeta.maxAmount &&
    loanAmount > Number(productMeta.maxAmount)
  ) {
    throw new Error(
      `Maximum allowed amount is ₦${Number(
        productMeta.maxAmount
      ).toLocaleString()}`
    );
  }

  /* ================= GENERATE ABBREVIATION ================= */
  let abbreviation = productMeta.abbreviation;

  if (!abbreviation && productMeta.name) {
    abbreviation = productMeta.name
      .split(" ")
      .map((w) => w[0])
      .join("")
      .toUpperCase();
  }

  if (!abbreviation) {
    throw new Error(
      `Abbreviation not set for loan product ${
        productMeta.name || productCode
      }`
    );
  }

  /* ================= GENERATE TRACKING ID ================= */
  const loanId = uuidv4();
  const prefix = abbreviation.toUpperCase();

  const dateStr = new Date()
    .toISOString()
    .slice(2, 10)
    .replace(/-/g, "");

  const seqResult = await client.query(`
    INSERT INTO loan_daily_sequence (loan_date, last_seq)
    VALUES (CURRENT_DATE, 1)
    ON CONFLICT (loan_date)
    DO UPDATE SET last_seq = loan_daily_sequence.last_seq + 1
    RETURNING last_seq
  `);

  const sequence = String(seqResult.rows[0].last_seq).padStart(4, "0");
  const loanCode = `${prefix}-${dateStr}-${sequence}`;

  /* ================= RESOLVE ACCOUNT OFFICER ================= */
  const resolvedStaffId =
  crmStaffId && crmStaffId !== ""
    ? Number(crmStaffId)
    : default_account_officer_id
      ? Number(default_account_officer_id)
      : null;
  /* ================= CREATE LOAN ================= */
  await client.query(
    `
    INSERT INTO loans (
      id,
      loan_code,
      session_id,
      crm_staff_id,
      product_code,
      salary_account_number,
      status,
      core_status,
      disbursement_status,
      created_at
    )
    VALUES (
      $1, $2, $3, $4, $5, $6,
      'PENDING_REVIEW',
      'NOT_CREATED',
      'NOT_DISBURSED',
      NOW()
    )
    `,
    [
      loanId,
      loanCode,
      loanSessionId,
      resolvedStaffId,
      productCode,
      salaryAccountNumber,
    ]
  );

  /* ================= ENRICH BANK NAME BEFORE SAVING ================= */

/* ================= SAVE BANK NAME FROM FRONTEND ================= */

const bankCode =
  dynamic.field_bank_code ||
  dynamic.bank_code ||
  null;

const bankName =
  dynamic.field_bank_name_name ||
  dynamic.bank_name ||
  null;

if (bankCode) {
  dynamic.bank_code = bankCode;
}

if (bankName) {
  dynamic.bank_name = bankName;
}

/* ================= SAVE DYNAMIC ANSWERS ================= */
await client.query(
  `
  INSERT INTO loan_answers (loan_id, answers)
  VALUES ($1, $2)
  `,
  [loanId, JSON.stringify(dynamic)]
);

await client.query("COMMIT");
  return {
    success: true,
    message: "Loan submitted successfully and awaiting approval",
    loanId,
    loanCode,
  };
} catch (err) {

  await client.query("ROLLBACK");

  console.error("❌ Loan creation failed:", err.message);

  throw err;

} finally {

  client.release();

}
}
static async validateSalaryAccount(loanId, externalClient = null) {

  const client = externalClient || await pool.connect();

  try {

    /* =====================================================
       1️⃣ LOAD LOAN + SESSION DATA
    ===================================================== */
    const loanRes = await client.query(`
     SELECT
  l.salary_account_number,
  ls.salary_bank_code,
  la.answers,
  ls.first_name,
  ls.last_name
      FROM loans l
      JOIN loan_answers la ON la.loan_id = l.id
      JOIN loan_sessions ls ON ls.id = l.session_id
      WHERE l.id = $1
    `, [loanId]);

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];




    if (!loan.salary_account_number) {
      throw new Error("Salary account number missing");
    }

    const parsedAnswers =
      typeof loan.answers === "string"
        ? JSON.parse(loan.answers)
        : loan.answers || {};

    /* =====================================================
       2️⃣ DETECT BANK CODE
    ===================================================== */
let bankCode =
  loan.salary_bank_code ||
  parsedAnswers.field_select_bank ||
  parsedAnswers.bank_code ||
  parsedAnswers.bank ||
  null;

if (!bankCode) {
  const bankKey = Object.keys(parsedAnswers).find(k =>
    k.toLowerCase().includes("bank") &&
    !k.toLowerCase().includes("name")
  );

  if (bankKey) {
    bankCode = parsedAnswers[bankKey];
  }
}

if (bankCode) {
  bankCode = String(bankCode).trim();
}

console.log("🔍 Parsed answers:", parsedAnswers);
console.log("🏦 Detected bank code:", bankCode);
    if (!bankCode) {
      const detectedKey = Object.keys(parsedAnswers).find(key =>
        key.toLowerCase().includes("bank") &&
        !key.toLowerCase().includes("name")
      );

      if (detectedKey) {
        bankCode = parsedAnswers[detectedKey];
      }
    }

    if (!bankCode) {
      throw new Error("Bank code missing");
    }

    /* =====================================================
       3️⃣ CALL NAME ENQUIRY
    ===================================================== */
    

const payload = {
  AccountNumber: String(loan.salary_account_number).trim(),
  BankCode: String(bankCode).trim(),
  Token: process.env.CORE_API_KEY
};

console.log("🔍 NAME ENQUIRY VALIDATION INPUT");
console.log("AccountNumber:", payload.AccountNumber);
console.log("BankCode:", payload.BankCode);
console.log("Token exists:", !!payload.Token);
console.log("Payload:", payload);

const nameEnquiry = await coreBankingClient.post(
  ENDPOINTS.TRANSFER.NAME_ENQUIRY,
  payload
);

console.log("🏦 NAME ENQUIRY RESPONSE:");
console.log(nameEnquiry?.data);
    if (!nameEnquiry?.data?.IsSuccessful) {
      return {
        success: false,
        valid: false,
        message:
          nameEnquiry?.data?.ResponseMessage ||
          "Invalid account number"
      };
    }

    // ✅ Correct field based on your API response
    const accountName = nameEnquiry?.data?.Name;

    if (!accountName) {
      throw new Error("Account name not returned from name enquiry");
    }

    /* =====================================================
       4️⃣ COMPARE NAMES
    ===================================================== */
    const bvnFullName = `${loan.first_name} ${loan.last_name}`;

    const isMatch = LoanService.isNameMatch(
      bvnFullName,
      accountName
    );

    if (!isMatch) {
      return {
        success: false,
        valid: false,
        message: "Account name mismatch",
        bvnName: bvnFullName,
        accountName
      };
    }

    /* =====================================================
       5️⃣ SAVE VERIFIED ACCOUNT NAME
    ===================================================== */
    await client.query(
      `
      UPDATE loans
      SET salary_account_name = $2
      WHERE id = $1
      `,
      [loanId, accountName]
    );

    return {
      success: true,
      valid: true,
      accountNumber: loan.salary_account_number,
      accountName
    };

  } catch (err) {

    console.error("❌ Salary validation error:", err.message);

    return {
      success: false,
      valid: false,
      message: err.message || "Unable to validate salary account"
    };

  } finally {
    if (!externalClient) client.release();
  }
}

/* * LOAN APPROVAL (CREDIT / ADMIN)*/
static async approveLoan(
  {
    loanId,
    approverId,
    comment,
    approved_amount,
    approved_tenor,
    approved_interest_rate
  },
  externalClient = null
)
{

 const client = externalClient || await pool.connect();
const manageTransaction = !externalClient;


  try {
   if (manageTransaction) {
  await client.query("BEGIN");
}

    const loanRes = await client.query(
      `
      SELECT status, core_status, product_code, crm_staff_id, session_id
      FROM loans
      WHERE id = $1
      FOR UPDATE
      `,
      [loanId]
    );

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];

    if (loan.status !== "PENDING_REVIEW") {
      throw new Error(`Loan cannot be approved. Current status: ${loan.status}`);
    }

    if (loan.crm_staff_id === approverId) {
      throw new Error("You cannot approve a loan you created.");
    }

    const duplicateCheck = await client.query(
      `
      SELECT 1
      FROM loan_approvals
      WHERE loan_id = $1
      AND approver_id = $2
      AND approval_status = 'APPROVED'
      `,
      [loanId, approverId]
    );

    if (duplicateCheck.rows.length) {
      throw new Error("You have already approved this loan.");
    }

    const loanConfig = await LoanService.getLoanSettings(client);

    const productConfig =
      loanConfig.productApprovals?.[loan.product_code];

    if (!productConfig) {
      throw new Error("Product approval configuration missing");
    }

    const requiredLevels =
      productConfig?.approvers || 1;

    const levelRes = await client.query(
      `
      SELECT COALESCE(MAX(approval_level), 0) AS current_level
      FROM loan_approvals
      WHERE loan_id = $1
      AND approval_status = 'APPROVED'
      `,
      [loanId]
    );

    const currentLevel = Number(levelRes.rows[0].current_level);
    const nextLevel = currentLevel + 1;

    if (nextLevel > requiredLevels) {
      throw new Error("All approval levels already completed");
    }

/* ✅ ADD VALIDATION HERE */
if (!approved_amount || approved_amount <= 0) {
  throw new Error("Approved amount must be provided before approval.");
}
    await client.query(
  `
  INSERT INTO loan_approvals
  (
    loan_id,
    approver_id,
    approval_level,
    approval_status,
    approval_reason,
    approved_amount,
    approved_tenor,
    approved_interest_rate
  )
  VALUES ($1,$2,$3,'APPROVED',$4,$5,$6,$7)
  `,
  [
    loanId,
    approverId,
    nextLevel,
    comment || null,
    approved_amount,
approved_tenor,
approved_interest_rate
  ]
);
    let finalStatus = "PENDING_NEXT_LEVEL";

    /* =====================================================
       FINAL LEVEL → RESOLVE ACCOUNT FIRST
    ===================================================== */
/* =====================================================
   FINAL LEVEL → RESOLVE ACCOUNT FIRST
===================================================== */
if (nextLevel === requiredLevels) {

  const oldStatus = loan.status;

  await client.query(`
    UPDATE loans
    SET status = 'APPROVED',
        approved_at = NOW(),
        updated_at = NOW()
    WHERE id = $1
  `, [loanId]);

  await LoanService.logLoanStatusChange(
    {
      loanId,
      oldStatus,
      newStatus: "APPROVED",
      changedBy: approverId,
      reason: "Final approval"
    },
    client
  );

  finalStatus = "APPROVED";
}

  if (manageTransaction) {
  await client.query("COMMIT");
}
return {
  success: true,
  level: nextLevel,
  finalStatus,
  message:
    finalStatus === "APPROVED"
      ? "Loan fully approved"
      : "Approval recorded. Awaiting next level"
};

  } catch (err) {

    if (manageTransaction) {
  await client.query("ROLLBACK");
}
    console.error("❌ LoanService Error:", {
      message: err.message,
      loanId,
      approverId,
    });

    throw err;

  } finally {
   if (manageTransaction) {
  client.release();
}

  }
}

static async resolveSettlementAccount(loanId, externalClient = null) {

  const client = externalClient || await pool.connect();
  const manageTransaction = !externalClient;

  try {

    if (manageTransaction) {
      await client.query("BEGIN");
    }

    const loanRes = await client.query(`
      SELECT 
        l.product_code,
        l.session_id,
        l.core_status,
        l.settlement_account_number,
        ls.core_customer_id
      FROM loans l
      JOIN loan_sessions ls
        ON ls.id = l.session_id
      WHERE l.id = $1
      FOR UPDATE
    `, [loanId]);

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];

    /* =====================================================
       🔁 ALREADY RESOLVED
    ===================================================== */
    if (
      loan.core_status === "ACCOUNT_RESOLVED" &&
      loan.settlement_account_number
    ) {
      if (manageTransaction) {
        await client.query("COMMIT");
      }

      return {
        success: true,
        accountNumber: loan.settlement_account_number,
        reused: true,
      };
    }

    const loanConfig = await LoanService.getLoanSettings(client);

    const productConfig =
      loanConfig.productApprovals?.[loan.product_code];

    if (!productConfig?.accountOpeningProductCode) {
      throw new Error("Settlement product not configured");
    }

    let customerId = loan.core_customer_id;

    /* =====================================================
       🆕 CUSTOMER DOES NOT EXIST → CREATE CUSTOMER + ACCOUNT
    ===================================================== */
    if (!customerId) {

      console.log("⚠️ Core customer not found. Using CreateCustomerAndAccount...");

      const created =
        await LoanService.createCustomerAndAccountFromSession(
          loan.session_id,
          productConfig.accountOpeningProductCode,
          client
        );

      if (!created?.customerId || !created?.accountNumber) {
        throw new Error("CreateCustomerAndAccount failed");
      }

      // Save customer ID
      await client.query(`
        UPDATE loan_sessions
        SET core_customer_id = $2
        WHERE id = $1
      `, [loan.session_id, created.customerId]);

      // Save settlement account
      await client.query(`
        UPDATE loans
        SET
          core_status = 'ACCOUNT_RESOLVED',
          settlement_account_number = $2
        WHERE id = $1
      `, [loanId, created.accountNumber]);

      if (manageTransaction) {
        await client.query("COMMIT");
      }

      return {
        success: true,
        accountNumber: created.accountNumber,
        reused: false,
      };
    }

    /* =====================================================
       🔒 TRANSITION TO ACCOUNT_CREATING
    ===================================================== */
    const updateRes = await client.query(`
      UPDATE loans
      SET core_status = 'ACCOUNT_CREATING'
      WHERE id = $1
      AND core_status != 'ACCOUNT_RESOLVED'
    `, [loanId]);

    // 🔒 Another process already resolved it
    if (updateRes.rowCount === 0) {

      const alreadyResolved = await client.query(`
        SELECT settlement_account_number
        FROM loans
        WHERE id = $1
      `, [loanId]);

      const existingAccount =
        alreadyResolved.rows[0]?.settlement_account_number;

      if (existingAccount) {
        return {
          success: true,
          accountNumber: existingAccount,
          reused: true,
        };
      }

      throw new Error("Unable to transition loan to ACCOUNT_CREATING");
    }

    /* =====================================================
       🏦 CUSTOMER EXISTS → CREATE ACCOUNT QUICK
    ===================================================== */
    const created = await LoanService.createAccountForCustomer(
      customerId,
      productConfig.accountOpeningProductCode,
      loan.session_id,
      client
    );

    if (!created?.accountNumber) {
      throw new Error("Account creation did not return account number");
    }

    await client.query(`
      UPDATE loans
      SET
        core_status = 'ACCOUNT_RESOLVED',
        settlement_account_number = $2
      WHERE id = $1
    `, [loanId, created.accountNumber]);

    if (manageTransaction) {
      await client.query("COMMIT");
    }

    return {
      success: true,
      accountNumber: created.accountNumber,
      reused: false,
    };

  } catch (err) {

    if (manageTransaction) {
      await client.query("ROLLBACK");
    }

    console.error("❌ resolveSettlementAccount error:", err.message);

    throw err;

  } finally {

    if (manageTransaction) {
      client.release();
    }

  }
}
static async createCustomerAndAccountFromSession(
  sessionId,
  productCode,
  externalClient = null
) {
  const client = externalClient || await pool.connect();
  const manageTransaction = !externalClient;

  try {
    if (manageTransaction) {
      await client.query("BEGIN");
    }

    /* ================= LOAD SESSION ================= */
    const sessionRes = await client.query(
      `
      SELECT *
      FROM loan_sessions
      WHERE id = $1
      LIMIT 1
      `,
      [sessionId]
    );

    if (!sessionRes.rows.length) {
      throw new Error("Loan session not found");
    }

    const session = sessionRes.rows[0];

    if (!session.bvn) {
      throw new Error("BVN missing from session");
    }

    /* ================= FORMAT DOB ================= */
    const dob = new Date(session.date_of_birth);

    if (!session.date_of_birth || isNaN(dob)) {
      throw new Error("Invalid date of birth");
    }

    const formattedDOB = dob
      .toLocaleDateString("en-GB", {
        day: "2-digit",
        month: "short",
        year: "numeric",
      })
      .replace(/ /g, "-");

    const trackingRef = `CUS-${uuidv4()}`;

    /* ================= BUILD PAYLOAD ================= */
    const payload = {
      TransactionTrackingRef: trackingRef,
      AccountOpeningTrackingRef: trackingRef,
      ProductCode: String(productCode),

      LastName: session.last_name,
      OtherNames: session.first_name,

      BVN: String(session.bvn),
      PhoneNo: session.phone_number,

      Gender:
        String(session.gender).toLowerCase() === "female"
          ? "Female"
          : "Male",

      PlaceOfBirth: session.place_of_birth || "Nigeria",
      DateOfBirth: formattedDOB,
      Address: session.address || "Nigeria",
      NationalIdentityNo: session.nin || "",

      NextOfKinPhoneNo: session.next_of_kin_phone || "",
      NextOfKinName: session.next_of_kin_name || "",

      ReferralPhoneNo: "",
      ReferralName: "",

      HasSufficientInfoOnAccountInfo: true,
      AccountInformationSource: 2,
      OtherAccountInformationSource: "Loan System",

      AccountOfficerCode: process.env.TEST_CORE_STAFF_CODE,

      Email:
        session.email && session.email.includes("@")
          ? session.email
          : `${trackingRef}@mutualtrust.local`,

      NotificationPreference: 0,
      TransactionPermission: 0,
      AccountTier: 3,
      AccountReferenceNumber: trackingRef.slice(-8),

      CustomerImage: session.customer_image_base64 || undefined,
      CustomerSignature: session.signature_base64 || undefined,
      IdentificationImage: session.id_card_base64 || undefined,
    };

    console.log("CREATE CUSTOMER & ACCOUNT PAYLOAD:");
    console.log(JSON.stringify(payload, null, 2));

    /* ================= CALL CORE ================= */
    const response = await coreBankingClient.post(
      ENDPOINTS.ACCOUNT.CREATE_CUSTOMER_AND_ACCOUNT,
      payload
    );

    console.log("🔥 FULL CREATE_CUSTOMER_AND_ACCOUNT RESPONSE:");
    console.log(JSON.stringify(response?.data, null, 2));

    if (!response?.data?.IsSuccessful) {
      throw new Error(
        response?.data?.Message ||
        "Core rejected CreateCustomerAndAccount"
      );
    }

    const data = response.data;
    const message = data?.Message || {};

    /* ================= EXTRACT IDS ================= */
    let customerId =
      message.CustomerID ||
      message.customerID ||
      message.CustomerIDInString ||
      data.CustomerID ||
      data.customerID ||
      null;

    let accountNumber =
      message.AccountNumber ||
      message.accountNumber ||
      message.NUBAN ||
      data.AccountNumber ||
      data.NUBAN ||
      null;

    /* ================= FALLBACK IF MISSING ================= */
   /* ================= FALLBACK IF MISSING ================= */
if (!customerId || !accountNumber) {

  console.log("⚠️ Core did not return IDs. Fetching via TrackingRef...");

  const fetchByTrackingRef = await coreBankingClient.get(
    ENDPOINTS.ACCOUNT.GET_BY_TRACKING_REF,
    {
      params: {
        transactionTrackingRef: trackingRef,
        computewithdrawableBalance: true
      }
    }
  );

  console.log("🔎 TRACKING REF RESPONSE:");
  console.log(JSON.stringify(fetchByTrackingRef?.data, null, 2));

  const accountData = fetchByTrackingRef?.data;

  if (!accountData || accountData.IsSuccessful === false) {
    throw new Error(
      accountData?.Message ||
      "Account created but could not fetch via tracking ref"
    );
  }

  accountNumber =
    accountData.AccountNumber ||
    accountData.NUBAN;

  customerId =
    accountData.CustomerID ||
    accountData.CustomerIDInString;

  if (!accountNumber) {
    throw new Error("Account number missing from tracking ref response");
  }
}
    if (!customerId || !accountNumber) {
      throw new Error("Core did not return IDs");
    }

    if (manageTransaction) {
      await client.query("COMMIT");
    }

    return {
      success: true,
      customerId,
      accountNumber,
      reused: false,
    };

  } catch (err) {
    if (manageTransaction) {
      await client.query("ROLLBACK");
    }

    console.error(
      "❌ createCustomerAndAccountFromSession error:",
      err.response?.data || err.message
    );

    throw err;

  } finally {
    if (manageTransaction) {
      client.release();
    }
  }
}




