  /**
 * ==================================================
 * CREATE LOAN IN CORE BANKING (BANKONE)
 * ==================================================
 * Only called AFTER internal approval
 */
static async createLoanInCoreBanking(
  loanId,
  overrides = {},
  externalClient = null
) {
  const client = externalClient || await pool.connect();
  const manageTransaction = !externalClient;

  try {
    if (manageTransaction) {
      await client.query("BEGIN");
    }

    /* ======================================================
       1️⃣ LOCK & LOAD LOAN
    ====================================================== */
    const loanRes = await client.query(
      `
      SELECT
        l.id,
        l.loan_code,
        l.status,
        l.product_code,
        l.core_status,
        l.core_loan_account_number,
        l.settlement_account_number,
        la.answers,
        ls.core_customer_id
      FROM loans l
      JOIN loan_answers la ON la.loan_id = l.id
      JOIN loan_sessions ls ON ls.id = l.session_id
      WHERE l.id = $1
      FOR UPDATE
      `,
      [loanId]
    );

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];

    if (loan.status !== "APPROVED") {
      throw new Error("Loan must be internally approved first");
    }

    /* ======================================================
       2️⃣ IDEMPOTENCY CHECK
    ====================================================== */
    if (
      loan.core_loan_account_number &&
      ["CREATED", "DISBURSED"].includes(loan.core_status)
    ) {
      return {
        success: true,
        loanAccountNumber: loan.core_loan_account_number
      };
    }

    if (!loan.core_customer_id) {
      throw new Error("Core customer ID missing");
    }

    if (!loan.settlement_account_number) {
      throw new Error("Settlement account not resolved");
    }

    const parsedAnswers =
      typeof loan.answers === "string"
        ? JSON.parse(loan.answers)
        : loan.answers || {};

    /* ======================================================
       3️⃣ EXTRACT AMOUNT
    ====================================================== */
    const amountKey = Object.keys(parsedAnswers)
  .find(k => k.toLowerCase().includes("amount"));

const originalAmount = Number(parsedAnswers[amountKey]);

const loanAmount =
  Number(overrides?.approved_amount) > 0
    ? Number(overrides.approved_amount)
    : originalAmount;


    if (!loanAmount || loanAmount <= 0) {
      throw new Error("Invalid loan amount");
    }

    /* ======================================================
       4️⃣ EXTRACT TENURE
    ====================================================== */
    const tenureKey = Object.keys(parsedAnswers)
      .find(k =>
        k.toLowerCase().includes("tenure") ||
        k.toLowerCase().includes("tenor")
      );

    const originalTenure = tenureKey
      ? Number(parsedAnswers[tenureKey])
      : null;

    const finalTenure =
      overrides.tenor ??
      overrides.tenure ??
      originalTenure;

    if (!finalTenure || finalTenure <= 0) {
      throw new Error("Invalid tenure");
    }

    /* ======================================================
       5️⃣ SAFE OVERRIDES
    ====================================================== */
    let finalInterestRate =
      overrides.interest_rate ??
      parsedAnswers.field_interest_rate ??
      24;

    if (!finalInterestRate || finalInterestRate < 5) {
      finalInterestRate = 24;
    }

    let finalMoratorium =
      overrides.moratorium ??
      parsedAnswers.field_moratorium ??
      0;

    finalMoratorium = Number(finalMoratorium) || 0;

    if (finalMoratorium >= finalTenure) {
      finalMoratorium = 0;
    }

    const finalComputationMode = 0; // Safe default

    /* ======================================================
       6️⃣ BUILD CORE PAYLOAD
    ====================================================== */
    const referenceNumber =
  loan.loan_code.replace(/\D/g, "").slice(0, 12);

const loanPayload = {
  TransactionTrackingRef: referenceNumber,
      LoanProductCode: String(loan.product_code),
      CustomerID: String(loan.core_customer_id),
      LinkedAccountNumber: String(loan.settlement_account_number),

      CollateralType: "SALARY",
      CollateralDetails:
        parsedAnswers.field_collateral_details ??
        "Salary-backed loan",

      ComputationMode: String(finalComputationMode),
      Tenure: String(finalTenure),
      Moratorium: String(finalMoratorium),

      InterestAccrualCommencementDate:
        new Date().toISOString().split("T")[0],

      Amount: String(loanAmount),
      InterestRate: String(finalInterestRate),

      PrincipalPaymentFrequency: "2",
      InterestPaymentFrequency: "2",
    };

    console.log("🚀 FINAL LOAN PAYLOAD:");
    console.log(JSON.stringify(loanPayload, null, 2));

    /* ======================================================
       7️⃣ CALL CORE (AUTO-FUNDS PRODUCT)
    ====================================================== */
    const coreResponse =
      await coreBankingClient.post(
        ENDPOINTS.LOAN.CREATE_APPLICATION,
        loanPayload
      );

    console.log("🔥 FULL CORE LOAN RESPONSE:");
    console.log(JSON.stringify(coreResponse?.data, null, 2));

    if (!coreResponse?.data?.IsSuccessful) {
      throw new Error(
        typeof coreResponse?.data?.Message === "string"
          ? coreResponse.data.Message
          : "Core rejected loan creation"
      );
    }

    const coreData = coreResponse.data;

    /* ======================================================
       8️⃣ EXTRACT FUNDED ACCOUNT NUMBER
    ====================================================== */
    let loanAccountNumber =
      coreData?.LoanAccountNumber ||
      coreData?.Message?.LoanAccountNumber ||
      coreData?.Message?.BankoneAccountNumber;

    /* ======================================================
       9️⃣ FALLBACK FETCH IF NOT RETURNED
    ====================================================== */
    if (!loanAccountNumber) {

      console.log("⚠️ Fetching loan via GetLoansByCustomerId...");

      const fetchLoans =
        await coreBankingClient.get(
          ENDPOINTS.LOAN.GET_BY_CUSTOMER_ID,
          {
            params: {
              CustomerId: String(loan.core_customer_id),
              institutionCode: INSTITUTION_CODE,
              addStartAndEndDate: "false",
            },
          }
        );

     const loansList =
  fetchLoans?.data?.Message?.Loans ||
  fetchLoans?.data?.Message ||
  fetchLoans?.data?.Loans ||
  [];


      const createdLoan = loansList.find(
        l =>
          String(l.TransactionTrackingRef) ===
          String(loan.loan_code)
      );

      loanAccountNumber =
        createdLoan?.LoanAccountNumber ||
        createdLoan?.loanAccountNumber;
    }

    if (!loanAccountNumber) {
      throw new Error(
        "Core loan account number not returned"
      );
    }

    /* ======================================================
       🔟 UPDATE DATABASE
    ====================================================== */
    await client.query(
`
UPDATE loans
SET core_status = 'CREATED',
    core_loan_account_number = $2,
    core_created_at = NOW()
WHERE id = $1
AND core_status = 'ACCOUNT_RESOLVED'`,
[loanId, loanAccountNumber]
);

    if (manageTransaction) {
      await client.query("COMMIT");
    }

    return {
      success: true,
      loanAccountNumber,
    };

  } catch (err) {

    if (manageTransaction) {
      await client.query("ROLLBACK");
    }

    console.error(
      "❌ createLoanInCoreBanking error:",
      err.message
    );

    throw err;

  } finally {
    if (manageTransaction) {
      client.release();
    }
  }
}
static async createAccountForCustomer(
  customerId,
  settlementProductCode, // renamed for clarity
  sessionId,
  externalClient = null
) {

  const client = externalClient || await pool.connect();
  const manageTransaction = !externalClient;

  try {

    if (manageTransaction) {
      await client.query("BEGIN");
    }

    /* ==============================
       1️⃣ VALIDATE PRODUCT CODE
    ============================== */

    const productCode = settlementProductCode;

    if (!productCode) {
      throw new Error("Settlement product code missing");
    }

    /* ==============================
       2️⃣ VERIFY CUSTOMER EXISTS IN CORE
    ============================== */

    let customerResponse;

    try {
      customerResponse = await coreBankingClient.get(
        ENDPOINTS.CUSTOMER.GET_BY_ID,
        {
          params: {
            CustomerID: String(customerId),
          },
        }
      );
    } catch (err) {
      throw new Error("Core customer validation failed");
    }

    const rawCustomer = customerResponse?.data;

    if (!rawCustomer || rawCustomer.IsSuccessful === false) {
      throw new Error(rawCustomer?.Message || "Customer not found in core");
    }

    const customer = rawCustomer?.Message || rawCustomer;

    if (!customer || (!customer.customerID && !customer.CustomerID)) {
      throw new Error("Customer not found in core");
    }

    console.log(
      "✅ Core customer verified:",
      customer.CustomerID || customer.customerID
    );

    /* ==============================
       3️⃣ CHECK IF ACCOUNT ALREADY EXISTS
    ============================== */

    const accountsResponse = await coreBankingClient.get(
      ENDPOINTS.ACCOUNT.GET_BY_CUSTOMER_ID,
      {
        params: {
          customerId: String(customerId),
        },
      }
    );

    const rawAccounts = accountsResponse?.data;

    let accounts = [];

    if (Array.isArray(rawAccounts?.Accounts)) {
      accounts = rawAccounts.Accounts;
    } else if (Array.isArray(rawAccounts?.Message)) {
      accounts = rawAccounts.Message;
    }

    const existingAccount = accounts.find(
      (acc) =>
        String(acc.ProductCode || acc.productCode) ===
        String(productCode)
    );

    if (existingAccount) {

      if (manageTransaction) {
        await client.query("COMMIT");
      }

      return {
        success: true,
        accountNumber:
          existingAccount.AccountNumber ||
          existingAccount.accountNumber,
        reused: true,
      };
    }

    /* ==============================
       4️⃣ CREATE NEW ACCOUNT
    ============================== */

    const loanConfig = await LoanService.getLoanSettings(client);

    const officerFromSettings =
      loanConfig?.coreDefaults?.accountOfficerCode || null;

    const finalOfficerCode =
      officerFromSettings ||
      process.env.TEST_CORE_STAFF_CODE;

    if (!finalOfficerCode) {
      throw new Error("Account officer code not configured");
    }

    const trackingRef =
  Date.now().toString().slice(-12);

    const sessionRes = await client.query(
      `
      SELECT bvn, date_of_birth
      FROM loan_sessions
      WHERE id = $1
      LIMIT 1
      `,
      [sessionId]
    );

    if (!sessionRes.rows.length) {
      throw new Error("Loan session not found");
    }

    const sessionData = sessionRes.rows[0];

    if (!sessionData?.bvn) {
      throw new Error("BVN missing from session");
    }

    const dob = new Date(sessionData.date_of_birth);

    if (!sessionData.date_of_birth || isNaN(dob)) {
      throw new Error("Invalid or missing date_of_birth in session");
    }

    const formattedDOB = dob
      .toLocaleDateString("en-GB", {
        day: "2-digit",
        month: "short",
        year: "numeric",
      })
      .replace(/ /g, "-");

    const rawPhone = customer.PhoneNo || customer.PhoneNumber || "";

    let normalizedPhone = rawPhone.replace(/\D/g, "");

    if (normalizedPhone.length === 10) {
      normalizedPhone = "0" + normalizedPhone;
    }

    if (
      normalizedPhone.startsWith("234") &&
      normalizedPhone.length === 13
    ) {
      normalizedPhone = "0" + normalizedPhone.slice(3);
    }

    if (normalizedPhone.length !== 11) {
      throw new Error("Invalid phone number format for core");
    }

    let genderValue = 0;

    if (
      customer.Gender === 1 ||
      String(customer.Gender).toLowerCase() === "female"
    ) {
      genderValue = 1;
    }

    const fullName =
      `${customer.LastName} ${customer.OtherNames}`.trim();

    const placeOfBirth =
      customer.PlaceOfBirth ||
      customer.placeOfBirth ||
      "Nigeria";

    const accountPayload = {
      TransactionTrackingRef: trackingRef,
      AccountOpeningTrackingRef: trackingRef,
      ProductCode: String(productCode),
      CustomerID: String(customerId),

      FullName: fullName,
      LastName: customer.LastName,
      OtherNames: customer.OtherNames,

      BVN: String(sessionData.bvn),
      PhoneNo: normalizedPhone,
      Gender: Number(genderValue),

      PlaceOfBirth: placeOfBirth,
      DateOfBirth: formattedDOB,
      Address: customer.Address || "Nigeria",

      AccountOfficerCode: String(finalOfficerCode),

      Email:
        customer.Email && customer.Email.includes("@")
          ? customer.Email
          : `${trackingRef}@mutualtrust.local`,

      NotificationPreference:
        loanConfig?.coreDefaults?.notificationPreference ?? 0,

      TransactionPermission: 0,
      AccountTier: 3,
      AccountReferenceNumber: trackingRef.slice(-6),
    };

    console.log(
      "FINAL ACCOUNT PAYLOAD:",
      JSON.stringify(accountPayload, null, 2)
    );

    const accountCreation = await coreBankingClient.post(
      ENDPOINTS.ACCOUNT.CREATE_ACCOUNT_QUICK,
      accountPayload
    );

    if (!accountCreation?.data?.IsSuccessful) {
      const creationMessage =
        accountCreation?.data?.Message?.CreationMessage ||
        accountCreation?.data?.Message ||
        "Core rejected account creation";

      throw new Error(
        typeof creationMessage === "string"
          ? creationMessage
          : JSON.stringify(creationMessage)
      );
    }

    const accountNumber =
      accountCreation?.data?.Message?.AccountNumber;

    if (!accountNumber) {
      throw new Error("Core did not return account number");
    }

    if (manageTransaction) {
      await client.query("COMMIT");
    }

    return {
      success: true,
      accountNumber,
      reused: false,
    };

  } catch (err) {

    if (manageTransaction) {
      await client.query("ROLLBACK");
    }

    console.error(
      "❌ createAccountForCustomer error:",
      err.response?.data || err.message
    );

    throw err;

  } finally {

    if (manageTransaction) {
      client.release();
    }
  }
}


/**
 * ==================================================
 * RETURN LOAN (FOR CORRECTION)
 * ==================================================
 */
static async returnLoan({ loanId, approverId, reason, files = [] }) {

 const client = await pool.connect();


  try {
    await client.query("BEGIN");

   const loanRes = await client.query(
  `SELECT status, crm_staff_id FROM loans WHERE id = $1 FOR UPDATE`,
  [loanId]
);

if (!loanRes.rows.length) {
  throw new Error("Loan not found");
}

const loan = loanRes.rows[0];

if (loan.status !== "PENDING_REVIEW") {
  throw new Error("Loan is no longer pending review");
}

if (loan.crm_staff_id === approverId) {
  throw new Error("You cannot perform this action on a loan you created.");
}


    const cleanReason = reason?.trim();

if (!cleanReason) {
  throw new Error("Reason is required.");
}


      // ✅ ADD THIS BLOCK HERE
    const approvalCheck = await client.query(
      `
      SELECT COUNT(*) AS approved_count
      FROM loan_approvals
      WHERE loan_id = $1
      AND approval_status = 'APPROVED'
      `,
      [loanId]
    );

    const approvedCount = Number(approvalCheck.rows[0].approved_count);

    if (approvedCount > 0) {
      throw new Error("Loan cannot be returned after partial approval.");
    }


    const approvalInsert = await client.query(
  `
  INSERT INTO loan_approvals
  (loan_id, approver_id, approval_level, approval_status, approval_reason)
  VALUES ($1, $2, 0, 'RETURNED', $3)
  RETURNING id
  `,
 [loanId, approverId, cleanReason]

);

const approvalId = approvalInsert.rows[0].id;
if (files?.length) {
  for (const file of files) {
  await client.query(
    `
    INSERT INTO loan_approval_files
    (loan_id, approval_id, file_name, file_path, uploaded_by)
    VALUES ($1, $2, $3, $4, $5)
    `,
    [
      loanId,
      approvalId,
      file.originalname,
      file.path,
      approverId
    ]
  );
}
  }

   const oldStatus = loan.status;

await client.query(
  `
  UPDATE loans
  SET status = 'RETURNED'
  WHERE id = $1
  `,
  [loanId]
);

await LoanService.logLoanStatusChange(
  {
    loanId,
    oldStatus,
    newStatus: "RETURNED",
    changedBy: approverId,
    reason: cleanReason
  },
  client
);

   await client.query("COMMIT");

    return { success: true };

 } catch (err) {
  await client.query("ROLLBACK");

  console.error("❌ LoanService Error:", {
    message: err.message,
    stack: err.stack,
    loanId: loanId || null,
    approverId: approverId || null,
  });

  throw err;
} finally {
  client.release();
}

}





/* ======================================================
   FULL LOAN LIFECYCLE (FINAL APPROVAL FLOW)
====================================================== */
static async processLoanLifecycle(
  loanId,
  approverId,
  overrides = {}
) {
  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK LOAN
    ===================================================== */
 const lockRes = await client.query(
  `SELECT * FROM loans WHERE id = $1 FOR UPDATE`,
  [loanId]
);

if (!lockRes.rows.length) {
  throw new Error("Loan not found");
}

let loan = lockRes.rows[0];
/* 🚫 PREVENT PROCESSING INVALID STATES */
if (loan.status === "REJECTED") {
  throw new Error("Rejected loans cannot be processed.");
}

if (loan.status === "RETURNED") {
  throw new Error("Returned loans must be corrected before processing.");
}


    if (loan.lifecycle_status === "BLOCKED_BY_DOCUMENT") {
  throw new Error("Loan is blocked due to rejected document.");
}

/* 🚫 PREVENT PROCESSING INVALID STATES */
if (loan.status === "REJECTED") {
  throw new Error("Rejected loans cannot be processed.");
}

if (loan.status === "RETURNED") {
  throw new Error("Returned loans must be corrected before processing.");
}

if (loan.lifecycle_status === "ACCOUNT_RESOLVED") {
  throw new Error(
    "Loan is currently being processed by another administrator."
  );
}

if (loan.lifecycle_status === "BLOCKED_BY_DOCUMENT") {
  throw new Error("Loan is blocked due to rejected document.");
}


    /* =====================================================
       🚫 BLOCK IF ANY DOCUMENT IS REJECTED
    ===================================================== */
    const rejectedDocs = await client.query(`
      SELECT lsd.id
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
     AND COALESCE(lsd.status, 'PENDING') = 'REJECTED'
    `, [loanId]);

    if (rejectedDocs.rows.length > 0) {
      throw new Error(
        "Loan cannot be processed while a document is rejected."
      );
    }
/* 🔒 LOCK LIFECYCLE */
await client.query(`
UPDATE loans
SET lifecycle_status = 'PROCESSING',
    updated_at = NOW()
WHERE id = $1
`, [loanId]);
    /* =====================================================
       2️⃣ PREVENT DOUBLE PROCESSING
    ===================================================== */
    if (loan.disbursement_status === "COMPLETED") {
      await client.query("COMMIT");
      return {
        success: true,
        message: "Loan already fully processed"
      };
    }

    const retryingTransfer =
      loan.disbursement_status === "AWAITING_MANUAL_FUNDING";

    /* =====================================================
       3️⃣ FINAL INTERNAL APPROVAL
    ===================================================== */
    if (!retryingTransfer && loan.status !== "APPROVED") {

      const approvalResult =
        await LoanService.approveLoan(
          { loanId, approverId, comment: "Final approval" },
          client
        );

      if (approvalResult.finalStatus !== "APPROVED") {
        await client.query("COMMIT");
        return {
          success: true,
          message: "Approval recorded. Awaiting next level."
        };
      }
    }

    /* =====================================================
       4️⃣ ENSURE SETTLEMENT ACCOUNT EXISTS
    ===================================================== */
    if (!retryingTransfer && loan.core_status !== "ACCOUNT_RESOLVED") {

      const settlement =
        await LoanService.resolveSettlementAccount(
          loanId,
          client
        );

      if (!settlement?.accountNumber) {
        throw new Error("Settlement account resolution failed");
      }

      const reload = await client.query(
        `SELECT * FROM loans WHERE id = $1`,
        [loanId]
      );

      loan = reload.rows[0];
    }

    /* =====================================================
       5️⃣ VALIDATE SALARY ACCOUNT
    ===================================================== */
    const salaryValidation =
      await LoanService.validateSalaryAccount(
        loanId,
        client
      );

    if (!salaryValidation?.valid) {
      throw new Error(
        salaryValidation?.message ||
        "Salary account validation failed"
      );
    }


    /* =====================================================
   🚫 BLOCK IF CUSTOMER HAS ACTIVE CORE LOAN
===================================================== */

if (loan.core_customer_id) {

  const coreLoansResponse =
    await LoanService.getLoansByCustomerId(
      loan.core_customer_id
    );

  const loansList =
    coreLoansResponse?.data?.Message?.Loans ||
    coreLoansResponse?.data?.Message ||
    coreLoansResponse?.data?.Loans ||
    [];

const activeCoreLoans = loansList.filter(l => {

  const status = String(
    l.LoanStatus || l.status || ""
  ).toUpperCase();

  const outstanding = Number(
    l.OutstandingBalance ||
    l.outstandingBalance ||
    0
  );

  const closedStatuses = [
    "CLOSED",
    "LIQUIDATED",
    "COMPLETED",
    "SETTLED"
  ];

  return (
    !closedStatuses.includes(status) &&
    outstanding > 0
  );
});

  if (activeCoreLoans.length > 0) {
    throw new Error(
      "Customer already has an active loan in core banking. Disbursement blocked."
    );
  }
}

    /* =====================================================
       6️⃣ CREATE LOAN IN CORE
    ===================================================== */
    let fundedAccount = loan.core_loan_account_number;

    if (!retryingTransfer && !fundedAccount) {

      const coreLoan =
        await LoanService.createLoanInCoreBanking(
          loanId,
          overrides,
          client
        );

      fundedAccount = coreLoan.loanAccountNumber;

      if (!fundedAccount) {
        throw new Error("Core funded account missing");
      }
    }

    /* =====================================================
       7️⃣ MARK AS DISBURSED TO SETTLEMENT
    ===================================================== */
    if (!retryingTransfer) {
      await client.query(`
UPDATE loans
SET core_status = 'DISBURSED',
    disbursement_status = 'DISBURSED_TO_SETTLEMENT'
WHERE id = $1
AND core_status = 'CREATED'
AND disbursement_status != 'COMPLETED'      `, [loanId]);
    }

    /* =====================================================
       8️⃣ LOAD UPDATED DATA
    ===================================================== */
    const reload = await client.query(`
      SELECT
       l.settlement_account_number,
       l.salary_account_number,
       l.salary_account_name,
       l.loan_code,
       l.transfer_tracking_ref,
       la.answers,
       ls.first_name,
       ls.last_name
FROM loans l
JOIN loan_answers la ON la.loan_id = l.id
JOIN loan_sessions ls ON ls.id = l.session_id
WHERE l.id = $1
  `, [loanId]);
    const updatedLoan = reload.rows[0];

    const answers =
      typeof updatedLoan.answers === "string"
        ? JSON.parse(updatedLoan.answers)
        : updatedLoan.answers || {};

    /* =====================================================
   GET APPROVED AMOUNT FROM APPROVAL TABLE
===================================================== */

const approvalRes = await client.query(`
  SELECT approved_amount
  FROM loan_approvals
  WHERE loan_id = $1
  AND approval_status = 'APPROVED'
  AND approved_amount IS NOT NULL
  ORDER BY approval_level DESC
  LIMIT 1
`, [loanId]);

let loanAmount = null;

if (approvalRes.rows.length) {
  loanAmount = Number(approvalRes.rows[0].approved_amount);
}

/* fallback to application amount if not found */
if (!loanAmount) {
  const amountKey = Object.keys(answers)
    .find(k => k.toLowerCase().includes("amount"));

  loanAmount = Number(answers[amountKey]);
}

if (!loanAmount || isNaN(loanAmount) || loanAmount <= 0) {
  throw new Error("Invalid loan amount detected before transfer");
}

console.log("💰 FINAL TRANSFER AMOUNT:", loanAmount);

    if (!loanAmount || loanAmount <= 0) {
      throw new Error("Invalid loan amount");
    }

    if (!updatedLoan.settlement_account_number) {
      throw new Error("Settlement account missing before transfer");
    }

    if (!updatedLoan.salary_account_number) {
      throw new Error("Salary account missing before transfer");
    }


// ✅ STOP HERE - NO TRANSFER YET
await client.query("COMMIT");

return {
  success: true,
  message: "Loan processed and disbursed to settlement account",
  requiresTransfer: true
};


    /* =====================================================
       🔟 FINALIZE
    ===================================================== */
  // 1️⃣ Get current values (row is already locked earlier with FOR UPDATE)
const currentRes = await client.query(
  `
  SELECT disbursement_status, lifecycle_status
  FROM loans
  WHERE id = $1
  `,
  [loanId]
);

const oldDisbursementStatus =
  currentRes.rows[0]?.disbursement_status || null;

const oldLifecycleStatus =
  currentRes.rows[0]?.lifecycle_status || null;

// 2️⃣ Update loan
await client.query(`
  UPDATE loans
  SET disbursement_status = 'COMPLETED',
      lifecycle_status = 'FULLY_PROCESSED',
      disbursed_at = NOW(),
      updated_at = NOW()
  WHERE id = $1
`, [loanId]);

// 3️⃣ Log disbursement change
await LoanService.logLoanStatusChange(
  {
    loanId,
    oldStatus: oldDisbursementStatus,
    newStatus: "COMPLETED",
    changedBy: approverId,
    reason: "Loan transfer successful"
  },
  client
);

// 4️⃣ Log lifecycle change
await LoanService.logLoanStatusChange(
  {
    loanId,
    oldStatus: oldLifecycleStatus,
    newStatus: "FULLY_PROCESSED",
    changedBy: approverId,
    reason: "Loan fully processed"
  },
  client
);

    /* =====================================================
       📄 AUTO-APPROVE ALL PENDING DOCUMENTS
    ===================================================== */
    await client.query(`
      UPDATE loan_session_documents lsd
      SET status = 'APPROVED',
          reviewed_by = $2,
          reviewed_at = NOW()
      FROM loans l
      WHERE l.id = $1
      AND l.session_id = lsd.session_id
      AND lsd.status = 'PENDING'
    `, [loanId, approverId]);

   

 await client.query("COMMIT");

return {
  success: true,
  message: "Loan processed successfully",
  loan: {
    loanCode: updatedLoan.loan_code,
    customerName: `${updatedLoan.first_name} ${updatedLoan.last_name}`,
    amount: loanAmount,
    settlementAccount: updatedLoan.settlement_account_number,
    destinationAccount: updatedLoan.salary_account_number,
    transferReference: transferRef
  }
};
  } catch (err) {

  await client.query("ROLLBACK");

  // Reset lifecycle if failure occurred
  await client.query(`
    UPDATE loans
    SET lifecycle_status = 'INITIAL',
        updated_at = NOW()
    WHERE id = $1
    AND lifecycle_status = 'PROCESSING'
  `, [loanId]);

  console.error("❌ Lifecycle error:", err.message);
  throw err;

  } finally {
    client.release();
  }
}




/**
 * ==================================================
 * REJECT LOAN (FINAL)
 * ==================================================
 */
static async rejectLoan({ loanId, approverId, reason, files = [] }) {

 const client = await pool.connect();

  try {
    await client.query("BEGIN");

    const loanRes = await client.query(
  `SELECT status, crm_staff_id FROM loans WHERE id = $1 FOR UPDATE`,
  [loanId]
);

if (!loanRes.rows.length) {
  throw new Error("Loan not found");
}

const loan = loanRes.rows[0];

if (loan.status !== "PENDING_REVIEW") {
  throw new Error("Loan is no longer pending review");
}

if (loan.crm_staff_id === approverId) {
  throw new Error("You cannot perform this action on a loan you created.");
}


   const cleanReason = reason?.trim();

if (!cleanReason) {
  throw new Error("Reason is required.");
}

    const approvalInsert = await client.query(
  `
  INSERT INTO loan_approvals
  (loan_id, approver_id, approval_level, approval_status, approval_reason)
  VALUES ($1, $2, 0, 'REJECTED', $3)
  RETURNING id
  `,
 [loanId, approverId, cleanReason]
);

const approvalId = approvalInsert.rows[0].id;

if (files?.length) {
  for (const file of files) {
  await client.query(
    `
    INSERT INTO loan_approval_files
    (loan_id, approval_id, file_name, file_path, uploaded_by)
    VALUES ($1, $2, $3, $4, $5)
    `,
    [
      loanId,
      approvalId,
      file.originalname,
      file.path,
      approverId
    ]
  );
}
}

    const oldStatus = loan.status;

await client.query(
  `
  UPDATE loans
  SET status = 'REJECTED',
      rejected_at = NOW()
  WHERE id = $1
  `,
  [loanId]
);

await LoanService.logLoanStatusChange(
  {
    loanId,
    oldStatus,
    newStatus: "REJECTED",
    changedBy: approverId,
    reason: cleanReason
  },
  client
);

   await client.query("COMMIT");

    return { success: true };

} catch (err) {
  await client.query("ROLLBACK");

  console.error("❌ LoanService Error:", {
    message: err.message,
    stack: err.stack,
    loanId: loanId || null,
    approverId: approverId || null,
  });

  throw err;
} finally {
  client.release();
}

}






/**
 * ==================================================
 * PREVIEW CORE BANKING LOAN PAYLOAD
 * ==================================================
 */
static async previewCoreLoanPayload(loanId) {

const client = await pool.connect();

try {

const loanRes = await client.query(
    `
    SELECT
      l.loan_code,
      l.product_code,
      la.answers,
      ls.core_customer_id AS customer_id,
      l.settlement_account_number
    FROM loans l
    JOIN loan_answers la ON la.loan_id = l.id
    JOIN loan_sessions ls ON ls.id = l.session_id
    WHERE l.id = $1
    `,
    [loanId]
  );

  if (!loanRes.rows.length) {
    throw new Error("Loan not found");
  }

  const loan = loanRes.rows[0];

  if (!loan.customer_id) {
    throw new Error("Core customer ID missing. Cannot create loan.");
  }

  const answers =
    typeof loan.answers === "string"
      ? JSON.parse(loan.answers)
      : loan.answers || {};

  /* ================= VALIDATIONS ================= */

  // 🔍 Detect amount dynamically
const amountKey = Object.keys(answers).find(
  key => key.toLowerCase().includes("amount")
);

const loanAmount = amountKey
  ? Number(answers[amountKey])
  : null;

if (!loanAmount || loanAmount <= 0) {
  throw new Error("Loan amount missing from application payload");
}

// 🔍 Detect tenure dynamically
const tenureKey = Object.keys(answers).find(
  key =>
    key.toLowerCase().includes("tenure") ||
    key.toLowerCase().includes("tenor")
);

const tenureValue = tenureKey
  ? answers[tenureKey]
  : null;

if (!tenureValue) {
  throw new Error("Loan tenure missing from application payload");
}

  

  /* ================= RETURN CORE PAYLOAD ================= */

return {
  TransactionTrackingRef: loan.loan_code,
  LoanProductCode: loan.product_code,
  CustomerID: String(loan.customer_id),
  LinkedAccountNumber: loan.settlement_account_number,

  CollateralType:
    answers.field_collateral_type ?? "SALARY",

  CollateralDetails:
    answers.field_collateral_details ??
    "Salary-backed loan",

  ComputationMode: "0",

  Tenure: String(tenureValue),


  Moratorium: String(
    answers.field_moratorium ?? 0
  ),

  InterestAccrualCommencementDate:
    new Date().toISOString().split("T")[0],

 Amount: String(loanAmount),


  InterestRate: String(
    answers.field_interest_rate ?? 24
  ),

  PrincipalPaymentFrequency: "2",
  InterestPaymentFrequency: "2",
};

} finally {
  client.release();
}
}


/**
 * ==================================================
 * GET PENDING LOAN APPROVALS
 * ==================================================
 */
/**
 * ==================================================
 * GET PENDING LOAN APPROVALS
 * ==================================================
 */
static async getPendingLoanApprovals(userRoleId) {

const client = await pool.connect();

try {

const res = await client.query(`
    SELECT
      l.id,
      l.loan_code,
      l.product_code,
      l.status,
      l.created_at,

      -- 🔥 MANDATE TRACKING
      l.mandate_sent,
      l.mandate_reference,
      l.mandate_sent_at,

      -- ================= RM =================
      l.crm_staff_id,
      CONCAT(
        INITCAP(u.first_name),
        ' ',
        INITCAP(u.last_name)
      ) AS rm_name,

      -- ================= PRODUCT NAME =================
      (ss.loan_settings->'productMeta'->l.product_code->>'name')
        AS product_name,

      -- ================= DIRECT DEBIT FLAG =================
      COALESCE(
        (ss.loan_settings->'productApprovals'->l.product_code->>'includeDirectDebit')::boolean,
        false
      ) AS include_direct_debit,

      -- ================= SESSION INFO =================
      ls.first_name,
      ls.last_name,
      ls.bvn,
      ls.nin,
      ls.core_customer_id,

      -- ================= VERIFICATION =================
      ls.verification_payload AS verification_payload,
      ls.face_verification_payload AS face_payload,
      ls.face_verification_status,
      ls.face_match_score,
      ls.face_verified_at,

      -- ================= LOAN ANSWERS =================
      la.answers AS application_payload,

      -- ================= DOCUMENTS =================
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'id', lsd.id,
            'doc_type',
              CASE
                WHEN lsd.id IS NOT NULL THEN lsd.doc_type
                ELSE 'ADMIN_ATTACHMENT'
              END,
            'file_path',
              CASE
                WHEN lsd.id IS NOT NULL THEN lsd.file_path
                ELSE laf.file_path
              END,
            'uploaded_at',
              CASE
                WHEN lsd.id IS NOT NULL THEN lsd.uploaded_at
                ELSE laf.created_at
              END,
            'status', lsd.status,
            'admin_comment', lsd.admin_comment,
            'reviewed_at', lsd.reviewed_at
          )
        ) FILTER (
          WHERE lsd.id IS NOT NULL
             OR laf.id IS NOT NULL
        ),
        '[]'
      ) AS documents,

      -- ================= APPROVAL HISTORY =================
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'approval_id', lap.id,
            'approval_status', lap.approval_status,
            'approval_level', lap.approval_level,
            'approval_reason', lap.approval_reason,
            'created_at', lap.created_at,
            'approver_name',
              CONCAT(
                INITCAP(ap.first_name),
                ' ',
                INITCAP(ap.last_name)
              )
          )
        ) FILTER (WHERE lap.id IS NOT NULL),
        '[]'
      ) AS approval_history

    FROM loans l

    LEFT JOIN users u
      ON u.id = l.crm_staff_id

    LEFT JOIN system_settings ss
      ON TRUE

    LEFT JOIN loan_sessions ls
      ON ls.id = l.session_id

    LEFT JOIN loan_answers la
      ON la.loan_id = l.id

    LEFT JOIN loan_session_documents lsd
      ON lsd.session_id = l.session_id

    LEFT JOIN loan_approval_files laf
      ON laf.loan_id = l.id

    -- 🔥 NEW JOINS FOR APPROVALS
    LEFT JOIN loan_approvals lap
      ON lap.loan_id = l.id

    LEFT JOIN users ap
      ON ap.id = lap.approver_id

    WHERE l.status IN (
      'PENDING_REVIEW',
      'RETURNED',
      'REJECTED',
      'APPROVED'
    )

    GROUP BY
      l.id,
      l.mandate_sent,
      l.mandate_reference,
      l.mandate_sent_at,
      u.first_name,
      u.last_name,
      ss.loan_settings,
      ls.id,
      la.answers

    ORDER BY l.created_at DESC
  `);

  const loanConfig = await LoanService.getLoanSettings();

const normalized = res.rows

.filter((loan) => {

  // Super Admin should see ALL loans
  if (Number(userRoleId) === 1) {
    return true;
  }

  const productConfig =
    loanConfig.productApprovals?.[loan.product_code];

  if (!productConfig) return false;

  const flow = productConfig.flow || [];

  const approvalHistory = Array.isArray(loan.approval_history)
    ? loan.approval_history
    : [];

  const approvedCount =
    approvalHistory.filter(
      (a) => a.approval_status === "APPROVED"
    ).length;

  const nextRole = flow[approvedCount];

  return Number(nextRole) === Number(userRoleId);

})
  .map((loan) => {
    const verification =
      typeof loan.verification_payload === "string"
        ? JSON.parse(loan.verification_payload)
        : loan.verification_payload || {};

    return {
      ...loan,

      include_direct_debit:
        loan.include_direct_debit === true,

      mandate_sent:
        loan.mandate_sent === true,

      mandate_reference:
        loan.mandate_reference || null,

      mandate_sent_at:
        loan.mandate_sent_at || null,

      approval_history:
        Array.isArray(loan.approval_history)
          ? loan.approval_history.sort(
              (a, b) =>
                new Date(a.created_at) -
                new Date(b.created_at)
            )
          : [],

      bvn_payload:
        verification?.bvn || verification || null,

      nin_payload:
        verification?.nin || null,
    };
  });

  return {
  data: normalized,
};

} finally {
  client.release();
}
}








static async checkCoreCustomerByLoanId(loanId) {

 

const client = await pool.connect();

  try {
    /* ================= GET LOAN + SESSION ================= */
    const loanRes = await client.query(
      `
      SELECT
        l.id,
        l.product_code,
        ls.id AS session_id,
        ls.core_customer_id
      FROM loans l
      JOIN loan_sessions ls ON ls.id = l.session_id
      WHERE l.id = $1
      `,
      [loanId]
    );

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];

    /* ================= REQUIRE SAVED CORE ID ================= */
    if (!loan.core_customer_id) {
      return {
        success: true,
        exists: false,
        message: "Core customer ID not saved",
      };
    }

    /* ================= VALIDATE CUSTOMER ================= */
    let customerResponse;

    try {
      customerResponse = await coreBankingClient.get(
        ENDPOINTS.CUSTOMER.GET_BY_ID,
        {
          params: {
            CustomerID: String(loan.core_customer_id),
          },
        }
      );
    } catch (err) {
      console.warn("Core validation failed:", err.message);

      return {
        success: true,
        exists: false,
        message: "Core validation failed",
      };
    }

    const rawCustomer = customerResponse?.data;

    if (!rawCustomer || rawCustomer.IsSuccessful === false) {
      return {
        success: true,
        exists: false,
        message: rawCustomer?.Message || "Customer not found in core",
      };
    }

    const customer = rawCustomer?.Message || rawCustomer;

    /* ================= FETCH ACCOUNTS ================= */
    let accountsResponse;

    try {
      accountsResponse = await coreBankingClient.get(
        ENDPOINTS.ACCOUNT.GET_BY_CUSTOMER_ID,
        {
          params: {
            customerId: String(loan.core_customer_id),
          },
        }
      );
    } catch (err) {
      console.warn("Account fetch failed:", err.message);

      return {
        success: true,
        exists: true,
        customer,
        accounts: [],
        corePayload: {
          Message: customer,
        },
      };
    }


    /* ================= NORMALIZE ACCOUNTS ================= */

   const rawAccounts =
  accountsResponse?.data?.Accounts ||
  accountsResponse?.data?.Message ||
  accountsResponse?.Accounts ||
  [];

   const accounts = rawAccounts.map((acc) => ({
  AccountNumber: acc.accountNumber || acc.AccountNumber,
  AccountStatus: acc.accountStatus || acc.AccountStatus,
  AccountType: acc.accountType || acc.AccountType,

  AvailableBalance: acc.availableBalance || acc.AvailableBalance,
  LedgerBalance: acc.ledgerBalance || acc.LedgerBalance,
  WithdrawableAmount:
    acc.withdrawableAmount || acc.WithdrawableAmount,

  ProductCode: acc.productCode || acc.ProductCode,
  Branch: acc.branch || acc.Branch,
  KycLevel: acc.kycLevel || acc.KycLevel,

  DateCreated: acc.dateCreated || acc.DateCreated,
  LastActivityDate:
    acc.lastActivityDate || acc.LastActivityDate,

  NUBAN: acc.NUBAN,
  CustomerID: acc.customerID || acc.CustomerID,
  AccessLevel: acc.accessLevel || acc.AccessLevel,
}));

/* ================= CHECK REQUIRED PRODUCT ================= */
const loanConfig = await LoanService.getLoanSettings(client);


const productConfig =
  loanConfig.productApprovals?.[loan.product_code];

const requiredProductCode =
  productConfig?.accountOpeningProductCode;

let hasRequiredProduct = false;

if (requiredProductCode) {
  hasRequiredProduct = accounts.some(
    (acc) =>
      String(acc.ProductCode) === String(requiredProductCode)
  );
}



    /* ================= RETURN CLEAN RESPONSE ================= */
   return {
  success: true,
  exists: true,
  customer,
  accounts,
  hasRequiredProduct,
  settlementAccountWillBeCreated: !hasRequiredProduct,
  corePayload: {
    Message: {
      ...customer,
      Accounts: accounts,
    },
  },
};

  } catch (err) {
    console.error("❌ checkCoreCustomerByLoanId Error:", err.message);
    throw err;
  } finally {
    client.release();
  }
}




static async syncCoreCustomerToSession(loanId, coreData) {
  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    const loanRes = await client.query(
      `SELECT session_id FROM loans WHERE id = $1`,
      [loanId]
    );

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const sessionId = loanRes.rows[0].session_id;

    await client.query(
      `
      UPDATE loan_sessions
      SET core_customer_id = $2
      WHERE id = $1
      `,
      [sessionId, coreData.customerID]
    );

    await client.query(
      `
      UPDATE loans
      SET core_status = 'ACCOUNT_RESOLVED',
          settlement_account_number = $2
      WHERE id = $1
      `,
      [loanId, coreData.accountNumber]
    );

    await client.query("COMMIT");

  } catch (err) {
    await client.query("ROLLBACK");
    throw err;
  } finally {
    client.release();
  }
}


/* ======================================================
   REJECT SINGLE DOCUMENT
====================================================== */
static async rejectDocument({
  loanId,
  documentId,
  approverId,
  reason
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    const cleanReason = reason?.trim();

    if (!cleanReason) {
      throw new Error("Rejection reason is required.");
    }

    /* =====================================================
       🔒 Lock Loan First (prevent lifecycle conflicts)
    ===================================================== */
    const loanRes = await client.query(`
      SELECT id, status, lifecycle_status, crm_staff_id
      FROM loans
      WHERE id = $1
      FOR UPDATE
    `, [loanId]);

    if (!loanRes.rows.length) {
      throw new Error("Loan not found.");
    }

    const loan = loanRes.rows[0];

    // ❌ Cannot reject document after full processing
    if (loan.lifecycle_status === "FULLY_PROCESSED") {
      throw new Error(
        "Cannot reject document. Loan already fully processed."
      );
    }

    /* =====================================================
       🔒 Lock Document Row (Only allow PENDING)
    ===================================================== */
    const docRes = await client.query(`
      SELECT id, status
      FROM loan_session_documents
      WHERE id = $1
      AND session_id = (
        SELECT session_id FROM loans WHERE id = $2
      )
      AND COALESCE(status, 'PENDING') != 'APPROVED'
      FOR UPDATE
    `, [documentId, loanId]);

    if (!docRes.rows.length) {
      throw new Error(
        "Document not found or cannot be rejected in current state."
      );
    }

    const document = docRes.rows[0];

    if (document.status === "REJECTED") {
      throw new Error("Document is already rejected.");
    }

    /* =====================================================
       ❌ Mark Document Rejected
    ===================================================== */
    await client.query(`
      UPDATE loan_session_documents
      SET status = 'REJECTED',
          admin_comment = $2,
          reviewed_by = $3,
          reviewed_at = NOW()
      WHERE id = $1
    `, [documentId, cleanReason, approverId]);

    /* =====================================================
       🔥 Update Loan Lifecycle
    ===================================================== */
    await client.query(`
   UPDATE loans
SET lifecycle_status = 'BLOCKED_BY_DOCUMENT',
    updated_at = NOW()
WHERE id = $1
    `, [loanId]);

    /* =====================================================
       🔔 Notify Relationship Manager
    ===================================================== */
    if (loan.crm_staff_id) {
      await client.query(`
        INSERT INTO notifications
        (user_id, type, message, reference_id, created_at)
        VALUES (
          $1,
          'DOCUMENT_REJECTED',
          'A document was rejected. Please review and re-upload.',
          $2,
          NOW()
        )
      `, [loan.crm_staff_id, loanId]);
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document rejected successfully."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ rejectDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}


/* ======================================================
   APPROVE SINGLE DOCUMENT
====================================================== */
static async approveDocument({
  loanId,
  documentId,
  approverId
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK PENDING DOCUMENT
    ===================================================== */
    const docRes = await client.query(`
      SELECT lsd.id, lsd.status, l.lifecycle_status
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.id = $2
      AND lsd.status = 'PENDING'
      FOR UPDATE
    `, [loanId, documentId]);

    if (!docRes.rows.length) {
      throw new Error(
        "Document not found or cannot be approved in current state."
      );
    }

    const { lifecycle_status } = docRes.rows[0];

    /* =====================================================
       2️⃣ APPROVE DOCUMENT
    ===================================================== */
    await client.query(`
      UPDATE loan_session_documents
      SET status = 'APPROVED',
          admin_comment = NULL,
          reviewed_by = $2,
          reviewed_at = NOW()
      WHERE id = $1
    `, [documentId, approverId]);

    /* =====================================================
       3️⃣ CHECK IF ANY REJECTED DOCUMENTS REMAIN
    ===================================================== */
    const rejectedCheck = await client.query(`
      SELECT 1
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.status = 'REJECTED'
      LIMIT 1
    `, [loanId]);

    /* =====================================================
       4️⃣ RESTORE LIFECYCLE IF SAFE
    ===================================================== */
    if (
      lifecycle_status === "BLOCKED_BY_DOCUMENT" &&
      rejectedCheck.rows.length === 0
    ) {
      await client.query(`
        UPDATE loans
        SET lifecycle_status = 'INITIAL'
        WHERE id = $1
      `, [loanId]);
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document approved successfully."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ approveDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}



/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
====================================================== */
/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
====================================================== */
/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
   Only allowed when loan status = RETURNED
====================================================== */
/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
   Only allowed when loan status = RETURNED
====================================================== */
static async reuploadDocument({
  documentId,
  filePath,
  fileName
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK DOCUMENT + LOAN
    ===================================================== */
    const docRes = await client.query(`
      SELECT 
        lsd.id,
        lsd.status AS document_status,
        l.id AS loan_id,
        l.lifecycle_status,
        l.status AS loan_status
      FROM loan_session_documents lsd
      JOIN loans l 
        ON l.session_id = lsd.session_id
      WHERE lsd.id = $1
      FOR UPDATE
    `, [documentId]);

    if (!docRes.rows.length) {
      throw new Error("Document not found.");
    }

    const document = docRes.rows[0];

    /* =====================================================
       2️⃣ STRICT BUSINESS RULE VALIDATION
    ===================================================== */

    // ❌ Prevent after full processing
    if (document.lifecycle_status === "FULLY_PROCESSED") {
      throw new Error(
        "Cannot re-upload document. Loan already fully processed."
      );
    }

    // 🔒 Only allow when loan is RETURNED
    if (document.loan_status !== "RETURNED") {
      throw new Error(
        "Documents can only be replaced when loan is returned."
      );
    }

    // 🔒 Only allow replacing rejected documents
    if (document.document_status !== "REJECTED") {
      throw new Error(
        "Only rejected documents can be replaced."
      );
    }

    /* =====================================================
       3️⃣ UPDATE DOCUMENT (Reset to PENDING)
    ===================================================== */
    await client.query(`
    UPDATE loan_session_documents
SET file_path = $2,
    status = 'PENDING',
    admin_comment = NULL,
    reviewed_by = NULL,
    reviewed_at = NULL,
    uploaded_at = NOW()
WHERE id = $1
    `, [documentId, filePath]);

    /* =====================================================
       4️⃣ CHECK IF ANY REJECTED DOCS REMAIN
    ===================================================== */
    const rejectedCheck = await client.query(`
      SELECT 1
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.status = 'REJECTED'
      LIMIT 1
    `, [document.loan_id]);

    /* =====================================================
       5️⃣ IF ALL DOCUMENTS FIXED → RESTORE LOAN
    ===================================================== */
    if (rejectedCheck.rows.length === 0) {

      // 🔥 Get current status for audit log
      const statusRes = await client.query(
        `SELECT status FROM loans WHERE id = $1`,
        [document.loan_id]
      );

      const oldStatus = statusRes.rows[0]?.status;

      // 🔥 Move loan back into approval flow
      await client.query(`
        UPDATE loans
        SET lifecycle_status = 'INITIAL',
            status = 'PENDING_REVIEW',
            updated_at = NOW()
        WHERE id = $1
      `, [document.loan_id]);

      // 🔥 Log status change
      await LoanService.logLoanStatusChange(
        {
          loanId: document.loan_id,
          oldStatus,
          newStatus: "PENDING_REVIEW",
          changedBy: null, // RM action (optional: pass RM ID if available)
          reason: "All rejected documents replaced"
        },
        client
      );
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document replaced and resubmitted for review."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ reuploadDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}

/* ======================================================
   GET LOANS FOR LOGGED-IN RM
====================================================== */
/* ======================================================
   GET LOANS FOR LOGGED-IN RM (WITH DOCUMENTS)
====================================================== */
static async getLoansByRmId(rmId) {

const client = await pool.connect();

try {

  const loanConfig = await LoanService.getLoanSettings();
  const res = await client.query(`
    SELECT
      l.id,
      l.loan_code,
      l.status,
      l.product_code,
      l.created_at,
      l.updated_at,
      l.returned_at,
      l.rejected_at,
      l.approved_at,
      l.lifecycle_status,
      l.disbursement_status,

      ls.first_name,
      ls.last_name,

      la.answers,

      /* ================= DOCUMENTS ================= */
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'id', lsd.id,
            'doc_type', lsd.doc_type,
            'file_path', lsd.file_path,

            /* 🔥 derive filename from path safely */
            'file_name',
              CASE
                WHEN lsd.file_path IS NOT NULL THEN
                  split_part(
                    lsd.file_path,
                    '/',
                    array_length(string_to_array(lsd.file_path, '/'), 1)
                  )
                ELSE NULL
              END,

            'status', COALESCE(lsd.status, 'PENDING'),
            'admin_comment', lsd.admin_comment,
            'reviewed_at', lsd.reviewed_at,
            'uploaded_at', lsd.uploaded_at
          )
        ) FILTER (WHERE lsd.id IS NOT NULL),
        '[]'
      ) AS documents,

      /* ================= APPROVAL HISTORY ================= */
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'approval_id', lap.id,
            'approval_status', lap.approval_status,
            'approval_level', lap.approval_level,
            'approval_reason', lap.approval_reason,
            'created_at', lap.created_at,
            'approver_name',
              CONCAT(
                INITCAP(u.first_name),
                ' ',
                INITCAP(u.last_name)
              )
          )
        ) FILTER (WHERE lap.id IS NOT NULL),
        '[]'
      ) AS approval_history,

      COALESCE(
        (
          SELECT MAX(approval_level)
          FROM loan_approvals
          WHERE loan_id = l.id
          AND approval_status = 'APPROVED'
        ),
        0
      ) AS current_level

    FROM loans l

    JOIN loan_sessions ls
      ON ls.id = l.session_id

    LEFT JOIN loan_answers la
      ON la.loan_id = l.id

    LEFT JOIN loan_session_documents lsd
      ON lsd.session_id = l.session_id

    LEFT JOIN loan_approvals lap
      ON lap.loan_id = l.id

    LEFT JOIN users u
      ON u.id = lap.approver_id

    WHERE l.crm_staff_id = $1

    GROUP BY
      l.id,
      ls.id,
      la.answers

    ORDER BY l.created_at DESC
  `, [rmId]);

  const loans = res.rows.map(row => {

    const productConfig =
      loanConfig.productApprovals?.[row.product_code] || {};

    const flow = productConfig.flow || [];
    const totalLevels = flow.length;
    const currentLevel = Number(row.current_level || 0);

    const isFullyApproved =
      totalLevels > 0 &&
      currentLevel >= totalLevels;

    const nextRoleId =
      !isFullyApproved
        ? flow[currentLevel]
        : null;

    const answers =
      typeof row.answers === "string"
        ? JSON.parse(row.answers)
        : row.answers || {};

    const amountKey = Object.keys(answers)
      .find(k => k.toLowerCase().includes("amount"));

    const approvalPercentage =
      totalLevels > 0
        ? Math.round((currentLevel / totalLevels) * 100)
        : 0;

    const progressLabel =
      `${currentLevel}/${totalLevels}`;

    const approvalFlow = flow.map((roleId, index) => {
      const role = loanConfig.roles?.find(
        r => String(r.id) === String(roleId)
      );

      return {
        level: index + 1,
        role_id: roleId,
        role_name: role?.name || `Level ${index + 1}`,
        completed: currentLevel > index,
        current: currentLevel === index
      };
    });

    let slaDeadline = null;
    let slaExpired = false;

    if (!isFullyApproved && row.status === "PENDING_REVIEW") {

      const slaHours =
        productConfig.slaHoursPerLevel || 24;

      const approvedHistory =
        Array.isArray(row.approval_history)
          ? row.approval_history
              .filter(a => a.approval_status === "APPROVED")
              .sort(
                (a, b) =>
                  new Date(a.created_at) -
                  new Date(b.created_at)
              )
          : [];

      const lastApproval =
        approvedHistory.length
          ? approvedHistory[approvedHistory.length - 1]
          : null;

      const baseTime =
        lastApproval?.created_at || row.created_at;

      const deadline = new Date(baseTime);
      deadline.setHours(deadline.getHours() + slaHours);

      slaDeadline = deadline;
      slaExpired = new Date() > deadline;
    }

    let pendingWith = null;

    if (row.status === "PENDING_REVIEW" && !isFullyApproved) {

      const role = loanConfig.roles?.find(
        r => String(r.id) === String(nextRoleId)
      );

      pendingWith =
        role?.name ||
        `Level ${currentLevel + 1}`;
    }

    if (row.status === "RETURNED") {
      pendingWith = "Relationship Manager";
    }

    if (row.status === "REJECTED") {
      pendingWith = null;
    }

    if (isFullyApproved &&
        row.disbursement_status !== "COMPLETED") {
      pendingWith = "Disbursement";
    }

    if (row.disbursement_status === "COMPLETED") {
      pendingWith = null;
    }

    return {
      id: row.id,
      loan_code: row.loan_code,
      status: row.status,
      lifecycle_status: row.lifecycle_status,
      disbursement_status: row.disbursement_status,
      product_code: row.product_code,

      product_name:
        loanConfig.productMeta?.[row.product_code]?.name ||
        row.product_code,

      created_at: row.created_at,
      updated_at: row.updated_at,
      approved_at: row.approved_at,
      rejected_at: row.rejected_at,
      returned_at: row.returned_at,

      approval_history:
        Array.isArray(row.approval_history)
          ? row.approval_history.sort(
              (a, b) =>
                new Date(a.created_at) -
                new Date(b.created_at)
            )
          : [],

      documents:
        Array.isArray(row.documents)
          ? row.documents
          : [],

      total_levels: totalLevels,
      current_level: currentLevel,
      next_level: nextRoleId,
      is_fully_approved: isFullyApproved,
      approval_percentage: approvalPercentage,
      approval_progress_label: progressLabel,
      approval_flow: approvalFlow,
      pending_with: pendingWith,

      sla_deadline: slaDeadline,
      sla_expired: slaExpired,

      customer_name:
        `${row.first_name} ${row.last_name}`,

      amount:
        amountKey ? Number(answers[amountKey]) : 0
    };
  });

 return {
  success: true,
  data: loans
};

} catch (err) {

  console.error("❌ getLoansByRmId error:", err.message);
  throw err;

} finally {

  client.release();

}
}



static async logLoanStatusChange(
  { loanId, oldStatus, newStatus, changedBy, reason = null },
  client
) {
  await client.query(
    `
    INSERT INTO loan_status_history
    (loan_id, old_status, new_status, changed_by, change_reason)
    VALUES ($1, $2, $3, $4, $5)
    `,
    [loanId, oldStatus, newStatus, changedBy, reason]
  );
}



/* ======================================================
   GET LOAN TRANSFERS (WITH FILTERS)
====================================================== */
static async getLoanTransfers({
  status = null,
  manualFunding = false,
  fromDate = null,
  toDate = null
} = {}) {

const client = await pool.connect();

try {

  const values = [];
  let whereConditions = [`lfe.event_type = 'TRANSFER'`];

  if (status) {
    values.push(status);
    whereConditions.push(`lfe.status = $${values.length}`);
  }

  if (manualFunding === true) {
    whereConditions.push(`l.disbursement_status = 'AWAITING_MANUAL_FUNDING'`);
  }

  if (fromDate) {
    values.push(fromDate);
    whereConditions.push(`lfe.created_at >= $${values.length}`);
  }

  if (toDate) {
    values.push(toDate);
    whereConditions.push(`lfe.created_at <= $${values.length}`);
  }

  const whereClause =
    whereConditions.length
      ? `WHERE ${whereConditions.join(" AND ")}`
      : "";

  const res = await client.query(`
    SELECT
      lfe.id,
      lfe.loan_id,
      lfe.reference,
      lfe.amount,
      lfe.status,
      lfe.created_at,
      lfe.core_response,
      l.loan_code,
      l.product_code,
      l.disbursement_status,
      l.lifecycle_status,
      CONCAT(ls.first_name, ' ', ls.last_name) AS customer_name
    FROM loan_financial_events lfe
    JOIN loans l ON l.id = lfe.loan_id
    JOIN loan_sessions ls ON ls.id = l.session_id
    ${whereClause}
    ORDER BY lfe.created_at DESC
  `, values);

  return {
    success: true,
    count: res.rows.length,
    data: res.rows
  };

} finally {
  client.release();
}
}
}
module.exports = LoanService;
