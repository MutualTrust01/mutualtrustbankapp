  );

  return (
    ref === String(loanAccountOpeningRefId || "") ||
    ref === String(loan.loan_code || "")
  );
});

      loanAccountNumber =
        createdLoan?.LoanAccountNumber ||
        createdLoan?.loanAccountNumber;
    }

    if (!loanAccountNumber) {
      throw new Error(
        "Core loan account number not returned"
      );
    }

    /* ======================================================
       🔟 UPDATE DATABASE
