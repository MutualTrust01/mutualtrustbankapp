/* * LOAN APPROVAL (CREDIT / ADMIN)*/
static async approveLoan(
  {
    loanId,
    approverId,
    comment,
    approved_amount,
    approved_tenor,
    approved_interest_rate
  },
  externalClient = null
)
{

 const client = externalClient || await pool.connect();
const manageTransaction = !externalClient;


  try {
   if (manageTransaction) {
  await client.query("BEGIN");
}

    const loanRes = await client.query(
      `
      SELECT status, core_status, product_code, crm_staff_id, session_id
      FROM loans
      WHERE id = $1
      FOR UPDATE
      `,
      [loanId]
    );

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];

    if (loan.status !== "PENDING_REVIEW") {
      throw new Error(`Loan cannot be approved. Current status: ${loan.status}`);
    }

    if (loan.crm_staff_id === approverId) {
      throw new Error("You cannot approve a loan you created.");
    }

    const duplicateCheck = await client.query(
      `
      SELECT 1
      FROM loan_approvals
      WHERE loan_id = $1
      AND approver_id = $2
      AND approval_status = 'APPROVED'
      `,
      [loanId, approverId]
    );

    if (duplicateCheck.rows.length) {
      throw new Error("You have already approved this loan.");
    }

    const loanConfig = await LoanService.getLoanSettings(client);

    const productConfig =
      loanConfig.productApprovals?.[loan.product_code];

    if (!productConfig) {
      throw new Error("Product approval configuration missing");
    }

    const requiredLevels =
      productConfig?.approvers || 1;

    const levelRes = await client.query(
      `
      SELECT COALESCE(MAX(approval_level), 0) AS current_level
      FROM loan_approvals
      WHERE loan_id = $1
      AND approval_status = 'APPROVED'
      `,
      [loanId]
    );

    const currentLevel = Number(levelRes.rows[0].current_level);
    const nextLevel = currentLevel + 1;

    if (nextLevel > requiredLevels) {
      throw new Error("All approval levels already completed");
    }

/* ✅ ADD VALIDATION HERE */
if (!approved_amount || approved_amount <= 0) {
  throw new Error("Approved amount must be provided before approval.");
}
    await client.query(
  `
  INSERT INTO loan_approvals
  (
    loan_id,
    approver_id,
    approval_level,
    approval_status,
    approval_reason,
    approved_amount,
    approved_tenor,
    approved_interest_rate
  )
  VALUES ($1,$2,$3,'APPROVED',$4,$5,$6,$7)
  `,
  [
    loanId,
    approverId,
    nextLevel,
    comment || null,
    approved_amount,
approved_tenor,
approved_interest_rate
  ]
);
    let finalStatus = "PENDING_NEXT_LEVEL";

    /* =====================================================
       FINAL LEVEL → RESOLVE ACCOUNT FIRST
    ===================================================== */
/* =====================================================
   FINAL LEVEL → RESOLVE ACCOUNT FIRST
===================================================== */
if (nextLevel === requiredLevels) {

  const oldStatus = loan.status;

  await client.query(`
    UPDATE loans
    SET status = 'APPROVED',
        approved_at = NOW(),
        updated_at = NOW()
    WHERE id = $1
  `, [loanId]);

  await LoanService.logLoanStatusChange(
    {
      loanId,
      oldStatus,
      newStatus: "APPROVED",
      changedBy: approverId,
      reason: "Final approval"
    },
    client
  );

  finalStatus = "APPROVED";
}

  if (manageTransaction) {
  await client.query("COMMIT");
}
return {
  success: true,
  level: nextLevel,
  finalStatus,
  message:
    finalStatus === "APPROVED"
      ? "Loan fully approved"
      : "Approval recorded. Awaiting next level"
};

  } catch (err) {

    if (manageTransaction) {
  await client.query("ROLLBACK");
}
    console.error("❌ LoanService Error:", {
      message: err.message,
      loanId,
      approverId,
    });

    throw err;

  } finally {
   if (manageTransaction) {
  client.release();
}

  }
}

static async resolveSettlementAccount(loanId, externalClient = null) {

  const client = externalClient || await pool.connect();
  const manageTransaction = !externalClient;

  try {

    if (manageTransaction) {
      await client.query("BEGIN");
    }

    const loanRes = await client.query(`
      SELECT 
        l.product_code,
        l.session_id,
        l.core_status,
        l.settlement_account_number,
        ls.core_customer_id
      FROM loans l
      JOIN loan_sessions ls
        ON ls.id = l.session_id
      WHERE l.id = $1
      FOR UPDATE
    `, [loanId]);

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];

let customerId = loan.core_customer_id;
    /* =====================================================
       🔁 ALREADY RESOLVED
    ===================================================== */
// ✅ ADD THIS BLOCK HERE
const loanConfig = await LoanService.getLoanSettings(client);

const productConfig =
  loanConfig.productApprovals?.[loan.product_code];


let accounts = [];

try {
  const accByCustomer = await coreBankingClient.get(
    ENDPOINTS.ACCOUNT.GET_BY_CUSTOMER_ID,
    {
      params: { customerId: String(loan.core_customer_id) }
    }
  );

  const raw1 = accByCustomer?.data;

  if (Array.isArray(raw1?.Message?.Accounts)) {
    accounts = raw1.Message.Accounts;
  } else if (Array.isArray(raw1?.Accounts)) {
    accounts = raw1.Accounts;
  } else if (Array.isArray(raw1?.Message)) {
    accounts = raw1.Message;
  }

  const seen = new Set();

  accounts = accounts.filter((acc) => {
    const key = String(
      acc.AccountNumber ||
      acc.accountNumber ||
      acc.NUBAN ||
      acc.nuban ||
      ""
    )
      .replace(/\s/g, "")
      .replace(/^0+/, "")
      .trim();

    if (!key || seen.has(key)) return false;

    seen.add(key);
    return true;
  });

} catch (err) {
  accounts = [];
}


if (!productConfig) {
  throw new Error("Product configuration missing");
}

const requiredProductCode =
  productConfig?.accountOpeningProductCode;

   
if (
  loan.core_status === "ACCOUNT_RESOLVED" &&
  loan.settlement_account_number
) {
  console.log("🔍 Validating existing settlement account...");



// ===== DEBUG =====
console.log("📦 CUSTOMER ACCOUNTS:", accounts.length);
  



const valid = accounts.find(acc => {
  const accNum = String(
    acc.AccountNumber ||
    acc.accountNumber ||
    acc.NUBAN ||
    ""
  )
    .replace(/\s/g, "")
    .replace(/^0+/, "")
    .trim();

  const loanAcc = String(
    loan.settlement_account_number || ""
  )
    .replace(/\s/g, "")
    .replace(/^0+/, "")
    .trim();

  return (
    accNum === loanAcc &&
    String(acc.ProductCode || acc.productCode) === String(requiredProductCode) &&
    String(acc.AccountStatus || acc.accountStatus).toUpperCase() === "ACTIVE"
  );
});
  if (valid) {
    console.log("✅ Existing settlement account is valid");

    if (manageTransaction) await client.query("COMMIT");

    return {
      success: true,
      accountNumber: loan.settlement_account_number,
      reused: true,
    };
  }

  console.log("⚠️ Stored account invalid → will create correct one");
}


/* =====================================================
   🔍 STEP 1: CHECK CORE IF NOT IN DB
===================================================== */

let coreCheck = null;

// ✅ ONLY call coreCheck if customerId is missing
if (!customerId) {
  console.log("🔍 No local customerId → checking core...");

  coreCheck = await LoanService.checkCoreCustomerByLoanId(loanId);

  if (coreCheck?.exists && coreCheck?.customer) {
    customerId =
      coreCheck.customer.CustomerID ||
      coreCheck.customer.customerID;

    console.log("✅ Customer exists in core:", customerId);

    await client.query(`
      UPDATE loan_sessions
      SET core_customer_id = $2
      WHERE id = $1
    `, [loan.session_id, customerId]);
  }
}

/* =====================================================
   ❌ STEP 2: STILL NOT FOUND → CREATE CUSTOMER + ACCOUNT
===================================================== */

if (!customerId) {

  console.log("❌ Customer not found anywhere → creating new");

  const created =
    await LoanService.createCustomerAndAccountFromSession(
      loan.session_id,
      productConfig.accountOpeningProductCode,
      client
    );

  await client.query(`
    UPDATE loan_sessions
    SET core_customer_id = $2
    WHERE id = $1
  `, [loan.session_id, created.customerId]);

  await client.query(`
    UPDATE loans
    SET core_status = 'ACCOUNT_RESOLVED',
        settlement_account_number = $2
    WHERE id = $1
  `, [loanId, created.accountNumber]);

  if (manageTransaction) await client.query("COMMIT");

  return {
    success: true,
    accountNumber: created.accountNumber,
    reused: false,
  };
}



/* =====================================================
   ✅ CUSTOMER EXISTS → CHECK IF ACCOUNT ALREADY EXISTS
===================================================== */



console.log("📦 Accounts received:",
accounts.map(a => ({
  acc: a.AccountNumber || a.accountNumber,
  product: a.ProductCode || a.productCode,
  status: a.AccountStatus || a.accountStatus
}))  
);

const existingAccount = accounts.find(acc =>
  String(acc.ProductCode || acc.productCode) === String(requiredProductCode) &&
  String(acc.AccountStatus || acc.accountStatus).toUpperCase() === "ACTIVE"
);

if (existingAccount?.AccountNumber) {

  console.log("✅ Reusing correct settlement account:",
    existingAccount.AccountNumber
  );

  await client.query(`
    UPDATE loans
    SET core_status = 'ACCOUNT_RESOLVED',
        settlement_account_number = $2
    WHERE id = $1
  `, [loanId, existingAccount.AccountNumber]);

  if (manageTransaction) {
    await client.query("COMMIT");
  }

  return {
    success: true,
    accountNumber: existingAccount.AccountNumber,
    reused: true,
  };
}


    /* =====================================================
       🔒 TRANSITION TO ACCOUNT_CREATING
    ===================================================== */
    const updateRes = await client.query(`
      UPDATE loans
      SET core_status = 'ACCOUNT_CREATING'
      WHERE id = $1
      AND core_status != 'ACCOUNT_RESOLVED'
    `, [loanId]);

    // 🔒 Another process already resolved it
    if (updateRes.rowCount === 0) {

      const alreadyResolved = await client.query(`
        SELECT settlement_account_number
        FROM loans
        WHERE id = $1
      `, [loanId]);

      const existingAccount =
        alreadyResolved.rows[0]?.settlement_account_number;

      if (existingAccount) {
        return {
          success: true,
          accountNumber: existingAccount,
          reused: true,
        };
      }

      throw new Error("Unable to transition loan to ACCOUNT_CREATING");
    }

    /* =====================================================
       🏦 CUSTOMER EXISTS → CREATE ACCOUNT QUICK
    ===================================================== */
    const created = await LoanService.createAccountForCustomer(
      customerId,
      productConfig.accountOpeningProductCode,
      loan.session_id,
      client
    );

    if (!created?.accountNumber) {
      throw new Error("Account creation did not return account number");
    }

    await client.query(`
      UPDATE loans
      SET
        core_status = 'ACCOUNT_RESOLVED',
        settlement_account_number = $2
      WHERE id = $1
    `, [loanId, created.accountNumber]);

    if (manageTransaction) {
      await client.query("COMMIT");
    }

    return {
      success: true,
      accountNumber: created.accountNumber,
      reused: false,
    };

  } catch (err) {

    if (manageTransaction) {
      await client.query("ROLLBACK");
    }

    console.error("❌ resolveSettlementAccount error:", err.message);

    throw err;

  } finally {

    if (manageTransaction) {
      client.release();
    }

  }
}
static async createCustomerAndAccountFromSession(
  sessionId,
  productCode,
  externalClient = null
) {
  const client = externalClient || await pool.connect();
  const manageTransaction = !externalClient;

  try {
    if (manageTransaction) {
      await client.query("BEGIN");
    }

    /* ================= LOAD SESSION ================= */
    const sessionRes = await client.query(
      `
      SELECT *
      FROM loan_sessions
      WHERE id = $1
      LIMIT 1
      `,
      [sessionId]
    );

    if (!sessionRes.rows.length) {
      throw new Error("Loan session not found");
    }

    const session = sessionRes.rows[0];

    if (!session.bvn) {
      throw new Error("[CUSTOMER_CREATION_KYC_ERROR] BVN missing from session");
    }

