class LoanService {

  static normalizeName(name) {
  return name
    .toLowerCase()
    .replace(/[^a-z\s]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}
static cleanBase64(base64) {
  if (!base64) return undefined;
  return base64.replace(/^data:image\/\w+;base64,/, "");
}

static isNameMatch(bvnFullName, accountName) {
  const cleanBVN = LoanService.normalizeName(bvnFullName);
  const cleanAccount = LoanService.normalizeName(accountName);

  // Strict full match
  if (cleanBVN === cleanAccount) return true;

  // Token match (safer fallback)
  const bvnParts = cleanBVN.split(" ");
  return bvnParts.every(part => cleanAccount.includes(part));
}

  /* ==================================================
   CENTRALIZED LOAN SETTINGS LOADER
================================================== */
static async getLoanSettings(client = null) {
  const db = client || pool;

  const res = await db.query(
    `SELECT loan_settings FROM system_settings LIMIT 1`
  );

  if (!res.rows.length) {
    throw new Error("Loan settings not found");
  }

  return res.rows[0].loan_settings || {};
}

  /**
   * ==================================================
   * PUBLIC LOAN SUBMISSION (INTERNAL ONLY)
   * ==================================================
   */
  static async createLoanApplication(payload) {
const client = await pool.connect();

try {
await client.query("BEGIN");
  const {
    loanSessionId,
    crmStaffId,
    productCode,
    dynamic = {},
  } = payload;

  /* ================= VALIDATE SESSION ================= */
  const sessionRes = await client.query(
    `
    SELECT id, bvn_verified_at, nin_verified_at
    FROM loan_sessions
    WHERE id = $1
    `,
    [loanSessionId]
  );

  if (!sessionRes.rows.length) {
    throw new Error("Invalid loan session");
  }

  const session = sessionRes.rows[0];

  
if (!session) {
  throw new Error("Customer verification incomplete");
}

  /* ================= PREVENT DUPLICATES ================= */
  const existingLoan = await client.query(
  `SELECT id FROM loans WHERE session_id = $1 FOR UPDATE`,
  [loanSessionId]
);

  if (existingLoan.rows.length) {
    throw new Error("Loan already submitted for this session");
  }

  /* ================= LOAD LOAN SETTINGS ================= */
  const loanConfig = await LoanService.getLoanSettings();

  const default_account_officer_id =
    loanConfig.defaultAccountOfficerId || null;

  /* ================= PRODUCT VALIDATION ================= */
  if (!productCode) {
    throw new Error("Loan product code missing");
  }

  const productMeta =
    loanConfig.productMeta?.[productCode];

  if (!productMeta) {
    throw new Error(`Loan product ${productCode} not configured`);
  }

  console.log("📦 Dynamic payload received:", dynamic);

  /* ================= SALARY ACCOUNT DETECTION ================= */
  /* ================= SALARY ACCOUNT DETECTION ================= */

// 1️⃣ Try strict known key first
let salaryAccountNumber =
  dynamic.field_account_number ||
  dynamic.salary_account_number ||
  dynamic.account_number ||
  null;

// 2️⃣ Fallback: try fuzzy detection
if (!salaryAccountNumber) {
  const detectedKey = Object.keys(dynamic).find(key =>
    key.toLowerCase().includes("account")
  );

  if (detectedKey) {
    salaryAccountNumber = String(dynamic[detectedKey]).trim();
  }
}

if (!salaryAccountNumber) {
  throw new Error("Salary account number is required");
}

if (!/^\d{10,11}$/.test(salaryAccountNumber)) {
  throw new Error("Invalid salary account number format");
}

console.log("Detected salary account:", salaryAccountNumber);

  /* ================= LOAN AMOUNT VALIDATION ================= */
  const amountField = Object.keys(dynamic).find(
    key => key.toLowerCase().includes("amount")
  );

  const loanAmount = Number(dynamic[amountField] || 0);

  console.log("Detected amount field:", amountField);
  console.log("Parsed loan amount:", loanAmount);

  if (!loanAmount || loanAmount <= 0) {
    throw new Error("Invalid loan amount");
  }

  if (
    productMeta.minAmount &&
    loanAmount < Number(productMeta.minAmount)
  ) {
    throw new Error(
      `Minimum allowed amount is ₦${Number(
        productMeta.minAmount
      ).toLocaleString()}`
    );
  }

  if (
    productMeta.maxAmount &&
    loanAmount > Number(productMeta.maxAmount)
  ) {
    throw new Error(
      `Maximum allowed amount is ₦${Number(
        productMeta.maxAmount
      ).toLocaleString()}`
    );
  }

  /* ================= GENERATE ABBREVIATION ================= */
  let abbreviation = productMeta.abbreviation;

  if (!abbreviation && productMeta.name) {
    abbreviation = productMeta.name
      .split(" ")
      .map((w) => w[0])
      .join("")
      .toUpperCase();
  }

  if (!abbreviation) {
    throw new Error(
      `Abbreviation not set for loan product ${
        productMeta.name || productCode
      }`
    );
  }

  /* ================= GENERATE TRACKING ID ================= */
  const loanId = uuidv4();
  const prefix = abbreviation.toUpperCase();

  const dateStr = new Date()
    .toISOString()
    .slice(2, 10)
    .replace(/-/g, "");

  const seqResult = await client.query(`
    INSERT INTO loan_daily_sequence (loan_date, last_seq)
    VALUES (CURRENT_DATE, 1)
    ON CONFLICT (loan_date)
    DO UPDATE SET last_seq = loan_daily_sequence.last_seq + 1
    RETURNING last_seq
  `);

  const sequence = String(seqResult.rows[0].last_seq).padStart(4, "0");
  const loanCode = `${prefix}-${dateStr}-${sequence}`;

  /* ================= RESOLVE ACCOUNT OFFICER ================= */
  const resolvedStaffId =
  crmStaffId && crmStaffId !== ""
    ? Number(crmStaffId)
    : default_account_officer_id
      ? Number(default_account_officer_id)
      : null;
  /* ================= CREATE LOAN ================= */
  await client.query(
    `
    INSERT INTO loans (
      id,
      loan_code,
      session_id,
      crm_staff_id,
      product_code,
      salary_account_number,
      status,
      core_status,
      disbursement_status,
      created_at
    )
    VALUES (
      $1, $2, $3, $4, $5, $6,
      'PENDING_REVIEW',
      'NOT_CREATED',
      'NOT_DISBURSED',
      NOW()
    )
    `,
    [
      loanId,
      loanCode,
      loanSessionId,
      resolvedStaffId,
      productCode,
      salaryAccountNumber,
    ]
  );

  /* ================= ENRICH BANK NAME BEFORE SAVING ================= */

/* ================= SAVE BANK NAME FROM FRONTEND ================= */

const bankCode =
  dynamic.field_bank_code ||
  dynamic.bank_code ||
  null;

const bankName =
  dynamic.field_bank_name ||
  dynamic.bank_name ||
  null;

if (bankCode) {
  dynamic.bank_code = bankCode;
}

if (bankName) {
  dynamic.bank_name = bankName;
}

/* ================= SAVE DYNAMIC ANSWERS ================= */
await client.query(
  `
  INSERT INTO loan_answers (loan_id, answers)
  VALUES ($1, $2)
  `,
  [loanId, JSON.stringify(dynamic)]
);

await client.query("COMMIT");
  return {
    success: true,
    message: "Loan submitted successfully and awaiting approval",
    loanId,
    loanCode,
  };
} catch (err) {

  await client.query("ROLLBACK");

  console.error("❌ Loan creation failed:", err.message);

  throw err;

} finally {

  client.release();

}
}
