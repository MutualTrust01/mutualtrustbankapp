    const approvalCheck = await client.query(
      `
      SELECT COUNT(*) AS approved_count
      FROM loan_approvals
      WHERE loan_id = $1
      AND approval_status = 'APPROVED'
      `,
      [loanId]
    );

    const approvedCount = Number(approvalCheck.rows[0].approved_count);

    if (approvedCount > 0) {
      throw new Error("Loan cannot be returned after partial approval.");
    }


