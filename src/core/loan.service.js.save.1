/**
 * ==================================================
 * PREVIEW CORE BANKING LOAN PAYLOAD
 * ==================================================
 */
static async previewCoreLoanPayload(loanId) {

const client = await pool.connect();

try {

const loanRes = await client.query(
    `
    SELECT
      l.loan_code,
      l.product_code,
      la.answers,
      ls.core_customer_id AS customer_id,
      l.settlement_account_number
    FROM loans l
    JOIN loan_answers la ON la.loan_id = l.id
    JOIN loan_sessions ls ON ls.id = l.session_id
    WHERE l.id = $1
    `,
    [loanId]
  );

  if (!loanRes.rows.length) {
    throw new Error("Loan not found");
  }

  const loan = loanRes.rows[0];

  if (!loan.customer_id) {
    throw new Error("Core customer ID missing. Cannot create loan.");
  }

  const answers =
    typeof loan.answers === "string"
      ? JSON.parse(loan.answers)
      : loan.answers || {};

  /* ================= VALIDATIONS ================= */

  // 🔍 Detect amount dynamically
const amountKey = Object.keys(answers).find(
  key => key.toLowerCase().includes("amount")
);

const loanAmount = amountKey
  ? Number(answers[amountKey])
  : null;

if (!loanAmount || loanAmount <= 0) {
  throw new Error("Loan amount missing from application payload");
}

// 🔍 Detect tenure dynamically
const tenureKey = Object.keys(answers).find(
  key =>
    key.toLowerCase().includes("tenure") ||
    key.toLowerCase().includes("tenor")
);

const tenureValue = tenureKey
  ? answers[tenureKey]
  : null;

if (!tenureValue) {
  throw new Error("Loan tenure missing from application payload");
}

  

  /* ================= RETURN CORE PAYLOAD ================= */

return {
  TransactionTrackingRef: loan.loan_code,
  LoanProductCode: loan.product_code,
  CustomerID: String(loan.customer_id),
  LinkedAccountNumber: loan.settlement_account_number,

  CollateralType:
    answers.field_collateral_type ?? "SALARY",

  CollateralDetails:
    answers.field_collateral_details ??
    "Salary-backed loan",

  ComputationMode: "0",

  Tenure: String(tenureValue),


  Moratorium: String(
    answers.field_moratorium ?? 0
  ),

  InterestAccrualCommencementDate:
    new Date().toISOString().split("T")[0],

 Amount: String(loanAmount),


  InterestRate: String(
    answers.field_interest_rate ?? 24
  ),

  PrincipalPaymentFrequency: "2",
  InterestPaymentFrequency: "2",
};

} finally {
  client.release();
}
}


/**
 * ==================================================
 * GET PENDING LOAN APPROVALS
 * ==================================================
 */
/**
 * ==================================================
 * GET PENDING LOAN APPROVALS
 * ==================================================
 */
static async getPendingLoanApprovals(userRoleId) {

const client = await pool.connect();

try {

const res = await client.query(`
    SELECT
      l.id,
      l.loan_code,
      l.product_code,
      l.status,
      l.created_at,

      -- 🔥 MANDATE TRACKING
      l.mandate_sent,
      l.mandate_reference,
      l.mandate_sent_at,

      -- ================= RM =================
      l.crm_staff_id,
      CONCAT(
        INITCAP(u.first_name),
        ' ',
        INITCAP(u.last_name)
      ) AS rm_name,

      -- ================= PRODUCT NAME =================
      (ss.loan_settings->'productMeta'->l.product_code->>'name')
        AS product_name,

      -- ================= DIRECT DEBIT FLAG =================
      COALESCE(
        (ss.loan_settings->'productApprovals'->l.product_code->>'includeDirectDebit')::boolean,
        false
      ) AS include_direct_debit,

      -- ================= SESSION INFO =================
      ls.first_name,
      ls.last_name,
      ls.bvn,
      ls.nin,
      ls.core_customer_id,

      -- ================= VERIFICATION =================
      ls.verification_payload AS verification_payload,
      ls.face_verification_payload AS face_payload,
      ls.face_verification_status,
      ls.face_match_score,
      ls.face_verified_at,

      -- ================= LOAN ANSWERS =================
      la.answers AS application_payload,

      -- ================= DOCUMENTS =================
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'id', lsd.id,
            'doc_type',
              CASE
                WHEN lsd.id IS NOT NULL THEN lsd.doc_type
                ELSE 'ADMIN_ATTACHMENT'
              END,
            'file_path',
              CASE
                WHEN lsd.id IS NOT NULL THEN lsd.file_path
                ELSE laf.file_path
              END,
            'uploaded_at',
              CASE
                WHEN lsd.id IS NOT NULL THEN lsd.uploaded_at
                ELSE laf.created_at
              END,
            'status', lsd.status,
            'admin_comment', lsd.admin_comment,
            'reviewed_at', lsd.reviewed_at
          )
        ) FILTER (
          WHERE lsd.id IS NOT NULL
             OR laf.id IS NOT NULL
        ),
        '[]'
      ) AS documents,

      -- ================= APPROVAL HISTORY =================
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'approval_id', lap.id,
            'approval_status', lap.approval_status,
            'approval_level', lap.approval_level,
            'approval_reason', lap.approval_reason,
            'created_at', lap.created_at,
            'approver_name',
              CONCAT(
                INITCAP(ap.first_name),
                ' ',
                INITCAP(ap.last_name)
              )
          )
        ) FILTER (WHERE lap.id IS NOT NULL),
        '[]'
      ) AS approval_history

    FROM loans l

    LEFT JOIN users u
      ON u.id = l.crm_staff_id

    LEFT JOIN system_settings ss
      ON TRUE

    LEFT JOIN loan_sessions ls
      ON ls.id = l.session_id

    LEFT JOIN loan_answers la
      ON la.loan_id = l.id

    LEFT JOIN loan_session_documents lsd
      ON lsd.session_id = l.session_id

    LEFT JOIN loan_approval_files laf
      ON laf.loan_id = l.id

    -- 🔥 NEW JOINS FOR APPROVALS
    LEFT JOIN loan_approvals lap
      ON lap.loan_id = l.id

    LEFT JOIN users ap
      ON ap.id = lap.approver_id

    WHERE l.status IN (
      'PENDING_REVIEW',
      'RETURNED',
      'REJECTED',
      'APPROVED'
    )

    GROUP BY
      l.id,
      l.mandate_sent,
      l.mandate_reference,
      l.mandate_sent_at,
      u.first_name,
      u.last_name,
      ss.loan_settings,
      ls.id,
      la.answers

    ORDER BY l.created_at DESC
  `);

  const loanConfig = await LoanService.getLoanSettings();

const normalized = res.rows

.filter((loan) => {

  // Super Admin should see ALL loans
  if (Number(userRoleId) === 1) {
    return true;
  }

  const productConfig =
    loanConfig.productApprovals?.[loan.product_code];

  if (!productConfig) return false;

  const flow = productConfig.flow || [];

  const approvalHistory = Array.isArray(loan.approval_history)
    ? loan.approval_history
    : [];

  const approvedCount =
    approvalHistory.filter(
      (a) => a.approval_status === "APPROVED"
    ).length;

  const nextRole = flow[approvedCount];

  return Number(nextRole) === Number(userRoleId);

})
  .map((loan) => {
  const verification =
    typeof loan.verification_payload === "string"
      ? JSON.parse(loan.verification_payload)
      : loan.verification_payload || {};

  // ✅ ADD THIS BLOCK
  let applicationPayload = loan.application_payload;

  if (typeof applicationPayload === "string") {
    try {
      applicationPayload = JSON.parse(applicationPayload);
    } catch (e) {
      applicationPayload = {};
    }
  }

  return {
    ...loan,

    // ✅ IMPORTANT: override with parsed payload
    application_payload: applicationPayload,

    include_direct_debit:
      loan.include_direct_debit === true,

      mandate_sent:
        loan.mandate_sent === true,

      mandate_reference:
        loan.mandate_reference || null,

      mandate_sent_at:
        loan.mandate_sent_at || null,

      approval_history:
        Array.isArray(loan.approval_history)
          ? loan.approval_history.sort(
              (a, b) =>
                new Date(a.created_at) -
                new Date(b.created_at)
            )
          : [],

      bvn_payload:
        verification?.bvn || verification || null,

      nin_payload:
        verification?.nin || null,
    };
  });

  return {
  data: normalized,
};

} finally {
  client.release();
}
}








