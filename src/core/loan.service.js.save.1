/* ======================================================
   FULL LOAN LIFECYCLE (FINAL APPROVAL FLOW)
====================================================== */
static async processLoanLifecycle(
  loanId,
  approverId,
  overrides = {}
) {
  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK LOAN
    ===================================================== */
 const lockRes = await client.query(
  `SELECT * FROM loans WHERE id = $1 FOR UPDATE`,
  [loanId]
);

if (!lockRes.rows.length) {
  throw new Error("Loan not found");
}

let loan = lockRes.rows[0];
/* 🚫 PREVENT PROCESSING INVALID STATES */
if (loan.status === "REJECTED") {
  throw new Error("Rejected loans cannot be processed.");
}

if (loan.status === "RETURNED") {
  throw new Error("Returned loans must be corrected before processing.");
}


    if (loan.lifecycle_status === "BLOCKED_BY_DOCUMENT") {
  throw new Error("Loan is blocked due to rejected document.");
}


if (loan.lifecycle_status === "PROCESSING") {
  throw new Error(
    "Loan is currently being processed by another administrator."
  );
}




    /* =====================================================
       🚫 BLOCK IF ANY DOCUMENT IS REJECTED
    ===================================================== */
    const rejectedDocs = await client.query(`
      SELECT lsd.id
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
     AND COALESCE(lsd.status, 'PENDING') = 'REJECTED'
    `, [loanId]);

    if (rejectedDocs.rows.length > 0) {
      throw new Error(
        "Loan cannot be processed while a document is rejected."
      );
    }
/* 🔒 LOCK LIFECYCLE */
await client.query(`
UPDATE loans
SET lifecycle_status = 'PROCESSING',
    updated_at = NOW()
WHERE id = $1
`, [loanId]);
    /* =====================================================
       2️⃣ PREVENT DOUBLE PROCESSING
    ===================================================== */
    if (loan.disbursement_status === "COMPLETED") {
      await client.query("COMMIT");
      return {
        success: true,
        message: "Loan already fully processed"
      };
    }

    const retryingTransfer =
      loan.disbursement_status === "AWAITING_MANUAL_FUNDING";

    /* =====================================================
       3️⃣ FINAL INTERNAL APPROVAL
    ===================================================== */
    if (!retryingTransfer && loan.status !== "APPROVED") {

      const approvalResult =
        await LoanService.approveLoan(
          { loanId, approverId, comment: "Final approval" },
          client
        );

      if (approvalResult.finalStatus !== "APPROVED") {
        await client.query("COMMIT");
        return {
          success: true,
          message: "Approval recorded. Awaiting next level."
        };
      }
    }

    /* =====================================================
       4️⃣ ENSURE SETTLEMENT ACCOUNT EXISTS
    ===================================================== */
    

// ✅ ALWAYS ensure settlement exists
if (!loan.settlement_account_number) {

  console.log("⚠️ Settlement missing → creating...");

  const settlement =
    await LoanService.resolveSettlementAccount(
      loanId,
      client
    );

  if (!settlement?.accountNumber) {
    throw new Error("Settlement account resolution failed");
  }

console.log("🔥 Reload loanId:", loanId);
  const reload = await client.query(
    `SELECT * FROM loans WHERE id = $1`,
    [loanId]
  );

console.log("🔥 Reload result:", reload.rows);

if (!reload.rows.length) {
  throw new Error("Loan not found at reload stage");
}

  loan = reload.rows[0];
}

    /* =====================================================
       5️⃣ VALIDATE SALARY ACCOUNT
    ===================================================== */
    const salaryValidation =
      await LoanService.validateSalaryAccount(
        loanId,
        client
      );

    if (!salaryValidation?.valid) {
      throw new Error(
        salaryValidation?.message ||
        "Salary account validation failed"
      );
    }


    /* =====================================================
   🚫 BLOCK IF CUSTOMER HAS ACTIVE CORE LOAN
===================================================== */

if (loan.core_customer_id) {

  const coreLoansResponse =
    await LoanService.getLoansByCustomerId(
      loan.core_customer_id
    );

  const loansList =
    coreLoansResponse?.data?.Message?.Loans ||
    coreLoansResponse?.data?.Message ||
    coreLoansResponse?.data?.Loans ||
    [];


console.log("🔥 CORE LOANS RAW:", JSON.stringify(loansList, null, 2));
const activeCoreLoans = loansList.filter(l => {

  const status = String(
    l.LoanStatus || l.status || ""
  ).toUpperCase();

  const outstanding = Number(
    l.OutstandingBalance ||
    l.outstandingBalance ||
    0
  );

  const closedStatuses = [
    "CLOSED",
    "LIQUIDATED",
    "COMPLETED",
    "SETTLED"
  ];

  return (
    !closedStatuses.includes(status) &&
    outstanding > 1
  );
});

  if (activeCoreLoans.length > 0) {
    throw new Error(
      "Customer already has an active loan in core banking. Disbursement blocked."
    );
  }
}

    /* =====================================================
       6️⃣ CREATE LOAN IN CORE
    ===================================================== */
    
let fundedAccount = loan.core_loan_account_number;

// ✅ ALWAYS reuse if exists
if (fundedAccount) {
  console.log("♻️ Reusing existing loan account:", fundedAccount);
}

// ✅ Only create if truly missing
if (!retryingTransfer && !fundedAccount) {

  console.log("🚀 Creating loan in core...");

  const coreLoan =
    await LoanService.createLoanInCoreBanking(
       loan.id,
      overrides,
      client
    );

  fundedAccount = coreLoan.loanAccountNumber;

  if (!fundedAccount) {
    throw new Error("Core funded account missing");
  }
}

    /* =====================================================
       7️⃣ MARK AS DISBURSED TO SETTLEMENT
    ===================================================== */
    if (!retryingTransfer) {
      
await client.query(`
UPDATE loans
SET core_status = 'DISBURSED',
    disbursement_status = 'COMPLETED',
    status = 'DISBURSED',
    disbursed_at = NOW()
WHERE id = $1
`, [loanId]);

    }

    /* =====================================================
       8️⃣ LOAD UPDATED DATA
    ===================================================== */
    const reload = await client.query(`
      SELECT
       l.settlement_account_number,
       l.salary_account_number,
       l.salary_account_name,
       l.loan_code,
       l.transfer_tracking_ref,
       la.answers,
       ls.first_name,
       ls.last_name
FROM loans l
JOIN loan_answers la ON la.loan_id = l.id
JOIN loan_sessions ls ON ls.id = l.session_id
WHERE l.id = $1
  `, [loanId]);
    const updatedLoan = reload.rows[0];

    const answers =
      typeof updatedLoan.answers === "string"
        ? JSON.parse(updatedLoan.answers)
        : updatedLoan.answers || {};

    /* =====================================================
   GET APPROVED AMOUNT FROM APPROVAL TABLE
===================================================== */

const approvalRes = await client.query(`
  SELECT approved_amount
  FROM loan_approvals
  WHERE loan_id = $1
  AND approval_status = 'APPROVED'
  AND approved_amount IS NOT NULL
  ORDER BY approval_level DESC
  LIMIT 1
`, [loanId]);

let loanAmount = null;

if (approvalRes.rows.length) {
  loanAmount = Number(approvalRes.rows[0].approved_amount);
}

/* fallback to application amount if not found */
if (!loanAmount) {
  const amountKey = Object.keys(answers)
    .find(k => k.toLowerCase().includes("amount"));

  loanAmount = Number(answers[amountKey]);
}

if (!loanAmount || isNaN(loanAmount) || loanAmount <= 0) {
  throw new Error("Invalid loan amount detected before transfer");
}

console.log("💰 FINAL TRANSFER AMOUNT:", loanAmount);

    if (!loanAmount || loanAmount <= 0) {
      throw new Error("Invalid loan amount");
    }

    if (!updatedLoan.settlement_account_number) {
      throw new Error("Settlement account missing before transfer");
    }

    if (!updatedLoan.salary_account_number) {
      throw new Error("Salary account missing before transfer");
    }


// ✅ STOP HERE - NO TRANSFER YET
await client.query("COMMIT");

return {
  success: true,
  message: "Loan processed and disbursed to settlement account",
  requiresTransfer: true
};

} catch (err) {
  await client.query("ROLLBACK");
  throw err;
} finally {
  client.release();
}
}

