static async returnLoan({ loanId, approverId, reason, files = [] }) {

 const client = await pool.connect();


  try {
    await client.query("BEGIN");

   const loanRes = await client.query(
  `SELECT status, crm_staff_id FROM loans WHERE id = $1 FOR UPDATE`,
  [loanId]
);

if (!loanRes.rows.length) {
  throw new Error("Loan not found");
}

const loan = loanRes.rows[0];

if (loan.status !== "PENDING_REVIEW") {
  throw new Error("Loan is no longer pending review");
}

if (loan.crm_staff_id === approverId) {
  throw new Error("You cannot perform this action on a loan you created.");
}


    const cleanReason = reason?.trim();

if (!cleanReason) {
  throw new Error("Reason is required.");
}


