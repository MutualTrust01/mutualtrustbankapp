static async syncCoreCustomerToSession(loanId, coreData) {
  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    const loanRes = await client.query(
      `SELECT session_id FROM loans WHERE id = $1`,
      [loanId]
    );

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const sessionId = loanRes.rows[0].session_id;

    await client.query(
      `
      UPDATE loan_sessions
      SET core_customer_id = $2
      WHERE id = $1
      `,
      [sessionId, coreData.customerID]
    );

    await client.query(
      `
      UPDATE loans
      SET core_status = 'ACCOUNT_RESOLVED',
          settlement_account_number = $2
      WHERE id = $1
      `,
      [loanId, coreData.accountNumber]
    );

    await client.query("COMMIT");

  } catch (err) {
    await client.query("ROLLBACK");
    throw err;
  } finally {
    client.release();
  }
}


/* ======================================================
   REJECT SINGLE DOCUMENT
====================================================== */
static async rejectDocument({
  loanId,
  documentId,
  approverId,
  reason
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    const cleanReason = reason?.trim();

    if (!cleanReason) {
      throw new Error("Rejection reason is required.");
    }

    /* =====================================================
       🔒 Lock Loan First (prevent lifecycle conflicts)
    ===================================================== */
    const loanRes = await client.query(`
      SELECT id, status, lifecycle_status, crm_staff_id
      FROM loans
      WHERE id = $1
      FOR UPDATE
    `, [loanId]);

    if (!loanRes.rows.length) {
      throw new Error("Loan not found.");
    }

    const loan = loanRes.rows[0];

    // ❌ Cannot reject document after full processing
    if (loan.lifecycle_status === "FULLY_PROCESSED") {
      throw new Error(
        "Cannot reject document. Loan already fully processed."
      );
    }

    /* =====================================================
       🔒 Lock Document Row (Only allow PENDING)
    ===================================================== */
    const docRes = await client.query(`
      SELECT id, status
      FROM loan_session_documents
      WHERE id = $1
      AND session_id = (
        SELECT session_id FROM loans WHERE id = $2
      )
      AND COALESCE(status, 'PENDING') != 'APPROVED'
      FOR UPDATE
    `, [documentId, loanId]);

    if (!docRes.rows.length) {
      throw new Error(
        "Document not found or cannot be rejected in current state."
      );
    }

    const document = docRes.rows[0];

    if (document.status === "REJECTED") {
      throw new Error("Document is already rejected.");
    }

    /* =====================================================
       ❌ Mark Document Rejected
    ===================================================== */
    await client.query(`
      UPDATE loan_session_documents
      SET status = 'REJECTED',
          admin_comment = $2,
          reviewed_by = $3,
          reviewed_at = NOW()
      WHERE id = $1
    `, [documentId, cleanReason, approverId]);

    /* =====================================================
       🔥 Update Loan Lifecycle
    ===================================================== */
    await client.query(`
   UPDATE loans
SET lifecycle_status = 'BLOCKED_BY_DOCUMENT',
    updated_at = NOW()
WHERE id = $1
    `, [loanId]);

    /* =====================================================
       🔔 Notify Relationship Manager
    ===================================================== */
    if (loan.crm_staff_id) {
      await client.query(`
        INSERT INTO notifications
        (user_id, type, message, reference_id, created_at)
        VALUES (
          $1,
          'DOCUMENT_REJECTED',
          'A document was rejected. Please review and re-upload.',
          $2,
          NOW()
        )
      `, [loan.crm_staff_id, loanId]);
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document rejected successfully."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ rejectDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}


/* ======================================================
   APPROVE SINGLE DOCUMENT
====================================================== */
static async approveDocument({
  loanId,
  documentId,
  approverId
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK PENDING DOCUMENT
    ===================================================== */
    const docRes = await client.query(`
      SELECT lsd.id, lsd.status, l.lifecycle_status
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.id = $2
      AND lsd.status = 'PENDING'
      FOR UPDATE
    `, [loanId, documentId]);

    if (!docRes.rows.length) {
      throw new Error(
        "Document not found or cannot be approved in current state."
      );
    }

    const { lifecycle_status } = docRes.rows[0];

    /* =====================================================
       2️⃣ APPROVE DOCUMENT
    ===================================================== */
    await client.query(`
      UPDATE loan_session_documents
      SET status = 'APPROVED',
          admin_comment = NULL,
          reviewed_by = $2,
          reviewed_at = NOW()
      WHERE id = $1
    `, [documentId, approverId]);

    /* =====================================================
       3️⃣ CHECK IF ANY REJECTED DOCUMENTS REMAIN
    ===================================================== */
    const rejectedCheck = await client.query(`
      SELECT 1
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.status = 'REJECTED'
      LIMIT 1
    `, [loanId]);

    /* =====================================================
       4️⃣ RESTORE LIFECYCLE IF SAFE
    ===================================================== */
    if (
      lifecycle_status === "BLOCKED_BY_DOCUMENT" &&
      rejectedCheck.rows.length === 0
    ) {
      await client.query(`
        UPDATE loans
        SET lifecycle_status = 'INITIAL'
        WHERE id = $1
      `, [loanId]);
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document approved successfully."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ approveDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}



/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
====================================================== */
/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
====================================================== */
/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
   Only allowed when loan status = RETURNED
====================================================== */
/* ======================================================
   RE-UPLOAD DOCUMENT (RM SIDE)
   Only allowed when loan status = RETURNED
====================================================== */
static async reuploadDocument({
  documentId,
  filePath,
  fileName
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK DOCUMENT + LOAN
    ===================================================== */
    const docRes = await client.query(`
      SELECT 
        lsd.id,
        lsd.status AS document_status,
        l.id AS loan_id,
        l.lifecycle_status,
        l.status AS loan_status
      FROM loan_session_documents lsd
      JOIN loans l 
        ON l.session_id = lsd.session_id
      WHERE lsd.id = $1
      FOR UPDATE
    `, [documentId]);

    if (!docRes.rows.length) {
      throw new Error("Document not found.");
    }

    const document = docRes.rows[0];

    /* =====================================================
       2️⃣ STRICT BUSINESS RULE VALIDATION
    ===================================================== */

    // ❌ Prevent after full processing
    if (document.lifecycle_status === "FULLY_PROCESSED") {
      throw new Error(
        "Cannot re-upload document. Loan already fully processed."
      );
    }

    // 🔒 Only allow when loan is RETURNED
    if (document.loan_status !== "RETURNED") {
      throw new Error(
        "Documents can only be replaced when loan is returned."
      );
    }

    // 🔒 Only allow replacing rejected documents
    if (document.document_status !== "REJECTED") {
      throw new Error(
        "Only rejected documents can be replaced."
      );
    }

    /* =====================================================
       3️⃣ UPDATE DOCUMENT (Reset to PENDING)
    ===================================================== */
    await client.query(`
    UPDATE loan_session_documents
SET file_path = $2,
    status = 'PENDING',
    admin_comment = NULL,
    reviewed_by = NULL,
    reviewed_at = NULL,
    uploaded_at = NOW()
WHERE id = $1
    `, [documentId, filePath]);

    /* =====================================================
       4️⃣ CHECK IF ANY REJECTED DOCS REMAIN
    ===================================================== */
    const rejectedCheck = await client.query(`
      SELECT 1
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.status = 'REJECTED'
      LIMIT 1
    `, [document.loan_id]);

    /* =====================================================
       5️⃣ IF ALL DOCUMENTS FIXED → RESTORE LOAN
    ===================================================== */
    if (rejectedCheck.rows.length === 0) {

      // 🔥 Get current status for audit log
      const statusRes = await client.query(
        `SELECT status FROM loans WHERE id = $1`,
        [document.loan_id]
      );

      const oldStatus = statusRes.rows[0]?.status;

      // 🔥 Move loan back into approval flow
      await client.query(`
        UPDATE loans
        SET lifecycle_status = 'INITIAL',
            status = 'PENDING_REVIEW',
            updated_at = NOW()
        WHERE id = $1
      `, [document.loan_id]);

      // 🔥 Log status change
      await LoanService.logLoanStatusChange(
        {
          loanId: document.loan_id,
          oldStatus,
          newStatus: "PENDING_REVIEW",
          changedBy: null, // RM action (optional: pass RM ID if available)
          reason: "All rejected documents replaced"
        },
        client
      );
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document replaced and resubmitted for review."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ reuploadDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}

/* ======================================================
   GET LOANS FOR LOGGED-IN RM
====================================================== */
/* ======================================================
   GET LOANS FOR LOGGED-IN RM (WITH DOCUMENTS)
====================================================== */
static async getLoansByRmId(rmId) {

const client = await pool.connect();

try {

  const loanConfig = await LoanService.getLoanSettings();
  const res = await client.query(`
    SELECT
      l.id,
      l.loan_code,
      l.status,
      l.product_code,
      l.created_at,
      l.updated_at,
      l.returned_at,
      l.rejected_at,
      l.approved_at,
      l.lifecycle_status,
      l.disbursement_status,

      ls.first_name,
      ls.last_name,

      la.answers,

      /* ================= DOCUMENTS ================= */
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'id', lsd.id,
            'doc_type', lsd.doc_type,
            'file_path', lsd.file_path,

            /* 🔥 derive filename from path safely */
            'file_name',
              CASE
                WHEN lsd.file_path IS NOT NULL THEN
                  split_part(
                    lsd.file_path,
                    '/',
                    array_length(string_to_array(lsd.file_path, '/'), 1)
                  )
                ELSE NULL
              END,

            'status', COALESCE(lsd.status, 'PENDING'),
            'admin_comment', lsd.admin_comment,
            'reviewed_at', lsd.reviewed_at,
            'uploaded_at', lsd.uploaded_at
          )
        ) FILTER (WHERE lsd.id IS NOT NULL),
        '[]'
      ) AS documents,

      /* ================= APPROVAL HISTORY ================= */
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'approval_id', lap.id,
            'approval_status', lap.approval_status,
            'approval_level', lap.approval_level,
            'approval_reason', lap.approval_reason,
            'created_at', lap.created_at,
            'approver_name',
              CONCAT(
                INITCAP(u.first_name),
                ' ',
                INITCAP(u.last_name)
              )
          )
        ) FILTER (WHERE lap.id IS NOT NULL),
        '[]'
      ) AS approval_history,

      COALESCE(
        (
          SELECT MAX(approval_level)
          FROM loan_approvals
          WHERE loan_id = l.id
          AND approval_status = 'APPROVED'
        ),
        0
      ) AS current_level

    FROM loans l

    JOIN loan_sessions ls
      ON ls.id = l.session_id

    LEFT JOIN loan_answers la
      ON la.loan_id = l.id

    LEFT JOIN loan_session_documents lsd
      ON lsd.session_id = l.session_id

    LEFT JOIN loan_approvals lap
      ON lap.loan_id = l.id

    LEFT JOIN users u
      ON u.id = lap.approver_id

    WHERE l.crm_staff_id = $1

    GROUP BY
      l.id,
      ls.id,
      la.answers

    ORDER BY l.created_at DESC
  `, [rmId]);

  const loans = res.rows.map(row => {

    const productConfig =
      loanConfig.productApprovals?.[row.product_code] || {};

    const flow = productConfig.flow || [];
    const totalLevels = flow.length;
    const currentLevel = Number(row.current_level || 0);

    const isFullyApproved =
      totalLevels > 0 &&
      currentLevel >= totalLevels;

    const nextRoleId =
      !isFullyApproved
        ? flow[currentLevel]
        : null;

    const answers =
      typeof row.answers === "string"
        ? JSON.parse(row.answers)
        : row.answers || {};

    const amountKey = Object.keys(answers)
      .find(k => k.toLowerCase().includes("amount"));

    const approvalPercentage =
      totalLevels > 0
        ? Math.round((currentLevel / totalLevels) * 100)
        : 0;

    const progressLabel =
      `${currentLevel}/${totalLevels}`;

    const approvalFlow = flow.map((roleId, index) => {
      const role = loanConfig.roles?.find(
        r => String(r.id) === String(roleId)
      );

      return {
        level: index + 1,
        role_id: roleId,
        role_name: role?.name || `Level ${index + 1}`,
        completed: currentLevel > index,
        current: currentLevel === index
      };
    });

    let slaDeadline = null;
    let slaExpired = false;

    if (!isFullyApproved && row.status === "PENDING_REVIEW") {

      const slaHours =
        productConfig.slaHoursPerLevel || 24;

      const approvedHistory =
        Array.isArray(row.approval_history)
          ? row.approval_history
              .filter(a => a.approval_status === "APPROVED")
              .sort(
                (a, b) =>
                  new Date(a.created_at) -
                  new Date(b.created_at)
              )
          : [];

      const lastApproval =
        approvedHistory.length
          ? approvedHistory[approvedHistory.length - 1]
          : null;

      const baseTime =
        lastApproval?.created_at || row.created_at;

      const deadline = new Date(baseTime);
      deadline.setHours(deadline.getHours() + slaHours);

      slaDeadline = deadline;
      slaExpired = new Date() > deadline;
    }

    let pendingWith = null;

    if (row.status === "PENDING_REVIEW" && !isFullyApproved) {

      const role = loanConfig.roles?.find(
        r => String(r.id) === String(nextRoleId)
      );

      pendingWith =
        role?.name ||
        `Level ${currentLevel + 1}`;
    }

    if (row.status === "RETURNED") {
      pendingWith = "Relationship Manager";
    }

    if (row.status === "REJECTED") {
      pendingWith = null;
    }

    if (isFullyApproved &&
        row.disbursement_status !== "COMPLETED") {
      pendingWith = "Disbursement";
    }

    if (row.disbursement_status === "COMPLETED") {
      pendingWith = null;
    }

    return {
      id: row.id,
      loan_code: row.loan_code,
      status: row.status,
      lifecycle_status: row.lifecycle_status,
      disbursement_status: row.disbursement_status,
      product_code: row.product_code,

      product_name:
        loanConfig.productMeta?.[row.product_code]?.name ||
        row.product_code,

      created_at: row.created_at,
      updated_at: row.updated_at,
      approved_at: row.approved_at,
      rejected_at: row.rejected_at,
      returned_at: row.returned_at,

      approval_history:
        Array.isArray(row.approval_history)
          ? row.approval_history.sort(
              (a, b) =>
                new Date(a.created_at) -
                new Date(b.created_at)
            )
          : [],

      documents:
        Array.isArray(row.documents)
          ? row.documents
          : [],

      total_levels: totalLevels,
      current_level: currentLevel,
      next_level: nextRoleId,
      is_fully_approved: isFullyApproved,
      approval_percentage: approvalPercentage,
      approval_progress_label: progressLabel,
      approval_flow: approvalFlow,
      pending_with: pendingWith,

      sla_deadline: slaDeadline,
      sla_expired: slaExpired,

      customer_name:
        `${row.first_name} ${row.last_name}`,

      amount:
        amountKey ? Number(answers[amountKey]) : 0
    };
  });

 return {
  success: true,
  data: loans
};

} catch (err) {

  console.error("❌ getLoansByRmId error:", err.message);
  throw err;

} finally {

  client.release();

}
}



