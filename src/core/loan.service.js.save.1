static async createLoanInCoreBanking(
  loanId,
  overrides = {},
  externalClient = null
) {
console.log("🔥 createLoanInCoreBanking INPUT loanId:", loanId);

  const client = externalClient || await pool.connect();
  const manageTransaction = !externalClient;

  try {
    if (manageTransaction) {
      await client.query("BEGIN");
    }

    /* ======================================================
       1️⃣ LOCK & LOAD LOAN
    ====================================================== */
    const loanRes = await client.query(
      `
  SELECT
  l.id,
  l.loan_code,
  l.status,
  l.product_code,
  l.core_status,
  l.core_loan_account_number,
  l.settlement_account_number,
  la.answers,
  ls.core_customer_id
FROM loans l
JOIN loan_answers la ON la.loan_id = l.id
JOIN loan_sessions ls ON ls.id = l.session_id
WHERE l.id = $1
FOR UPDATE      `,
      [loanId]
    );

    if (!loanRes.rows.length) {
      throw new Error("Loan not found");
    }

    const loan = loanRes.rows[0];

    if (loan.status !== "APPROVED") {
      throw new Error("Loan must be internally approved first");
    }

    /* ======================================================
       2️⃣ IDEMPOTENCY CHECK
    ====================================================== */
    if (
      loan.core_loan_account_number &&
      ["CREATED", "DISBURSED"].includes(loan.core_status)
    ) {
      return {
        success: true,
        loanAccountNumber: loan.core_loan_account_number
      };
    }

    if (!loan.core_customer_id) {
      throw new Error("Core customer ID missing");
    }

    


    /* ======================================================
       3️⃣ EXTRACT AMOUNT
    ====================================================== */
    const originalAmount = Number(
  parsedAnswers.field_amount ||
  parsedAnswers.amount
);

const loanAmount =
  Number(overrides?.approved_amount) > 0
    ? Number(overrides.approved_amount)
    : originalAmount;


    if (!loanAmount || loanAmount <= 0) {
      throw new Error("Invalid loan amount");
    }

    /* ======================================================
       4️⃣ EXTRACT TENURE
    ====================================================== */
    const originalTenure = Number(
  parsedAnswers.field_tenure ||
  parsedAnswers.tenure ||
  parsedAnswers.tenor
);

    const finalTenure =
      overrides.tenor ??
      overrides.tenure ??
      originalTenure;

    if (!finalTenure || finalTenure <= 0) {
      throw new Error("Invalid tenure");
    }

    /* ======================================================
       5️⃣ SAFE OVERRIDES
    ====================================================== */
    let finalInterestRate =
      overrides.interest_rate ??
      parsedAnswers.field_interest_rate ??
      24;

    if (!finalInterestRate || finalInterestRate < 5) {
      finalInterestRate = 24;
    }


const loanConfig = await LoanService.getLoanSettings(client);



let rawMoratorium =
  overrides.approved_moratorium ??
  overrides.moratorium ??
  parsedAnswers.field_moratorium ??
parsedAnswers.moratorium ??
loanConfig.defaultMoratorium;
// ✅ check BEFORE converting
if (
  rawMoratorium === undefined ||
  rawMoratorium === null ||
  rawMoratorium === ""
) {
  rawMoratorium = 30;
}

let finalMoratorium = Number(rawMoratorium);

// fallback again if still bad
if (isNaN(finalMoratorium)) {
  finalMoratorium = 30;
}

// 🚨 rule
if (finalMoratorium >= finalTenure) {
  finalMoratorium = 0;
}


    const finalComputationMode = 1; // Safe default

    /* ======================================================
       6️⃣ BUILD CORE PAYLOAD


    ====================================================== */
 
const staffCode = process.env.TEST_CORE_STAFF_CODE;

if (!staffCode) {
  throw new Error("Account officer code is missing");
}

const productName = String(loan.product_code || "").toUpperCase();

// Adjust this if your product naming differs
const requiresIppis = productName.includes("PROMPT") || productName.includes("CASH");

const ippisValue =
  overrides?.ippis ??
  parsedAnswers?.field_ippis ??
  parsedAnswers?.ippis ??
  null;

console.log("IPPIS DEBUG:", {
  productName,
  requiresIppis,
  ippisValue
});


const loanPayload = {
  TransactionTrackingRef: loan.loan_code,

  LoanProductCode: String(loan.product_code),

  CustomerID: String(loan.core_customer_id),

  LinkedAccountNumber: String(loan.settlement_account_number),

  CollateralType: "SALARY",

  CollateralDetails:
    parsedAnswers.field_collateral_details ||
    "Salary-backed loan",

  ComputationMode: finalComputationMode,

Tenure: String(finalTenure),
Moratorium: String(finalMoratorium),  

InterestAccrualCommencementDate:
  new Date().toISOString().split("T")[0],

  Amount: String(loanAmount),
InterestRate: String(finalInterestRate),

PrincipalPaymentFrequency: "2",
InterestPaymentFrequency: "2",

PrincipalRepaymentType: "1",
InterestRepaymentType: "1",
InterestAccrualMode: "1",


AccountOfficerStaffCode: String(staffCode),

EconomicSector: "1",

  DoNotApplyLoanFees: false,

 ...(requiresIppis && ippisValue
  ? { IPPIS: String(ippisValue) }
  : {}),

};


    console.log("🚀 FINAL LOAN PAYLOAD:");
    console.log(JSON.stringify(loanPayload, null, 2));

    /* ======================================================
       7️⃣ CALL CORE (AUTO-FUNDS PRODUCT)
    ====================================================== */
    const coreResponse =
      await coreBankingClient.post(
        ENDPOINTS.LOAN.CREATE_APPLICATION,
        loanPayload
      );

 console.log("🔥 FULL CORE LOAN RESPONSE:");
console.log(JSON.stringify(coreResponse?.data, null, 2));

/* ================= EXTRACT TRACKING REF ================= */
const loanAccountOpeningRefId =
  coreResponse?.data?.TransactionTrackingRef ||
  coreResponse?.data?.transactionTrackingRef ||
  coreResponse?.data?.Message?.TransactionTrackingRef ||
  coreResponse?.data?.message?.transactionTrackingRef ||
  null;

console.log("📌 Extracted loan_account_opening_refid:", loanAccountOpeningRefId);

    
    if (!coreResponse?.data?.IsSuccessful) {
      throw new Error(
        typeof coreResponse?.data?.Message === "string"
          ? coreResponse.data.Message
          : "Core rejected loan creation"
      );
    }

    const coreData = coreResponse.data;

    /* ======================================================
       8️⃣ EXTRACT FUNDED ACCOUNT NUMBER
    ====================================================== */
    
let loanAccountNumber =
  coreData?.LoanAccountNumber ||
  coreData?.Message?.LoanAccountNumber ||
  null;
    /* ======================================================
       9️⃣ FALLBACK FETCH IF NOT RETURNED
    ====================================================== */
    if (!loanAccountNumber) {

      console.log("⚠️ Fetching loan via GetLoansByCustomerId...");

      const fetchLoans =
        await coreBankingClient.get(
          ENDPOINTS.LOAN.GET_BY_CUSTOMER_ID,
          {
            params: {
