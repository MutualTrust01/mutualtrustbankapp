/* ======================================================
   REJECT SINGLE DOCUMENT
====================================================== */
static async rejectDocument({
  loanId,
  documentId,
  approverId,
  reason
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    const cleanReason = reason?.trim();

    if (!cleanReason) {
      throw new Error("Rejection reason is required.");
    }

    /* =====================================================
       🔒 Lock Loan First (prevent lifecycle conflicts)
    ===================================================== */
    const loanRes = await client.query(`
      SELECT id, status, lifecycle_status, crm_staff_id
      FROM loans
      WHERE id = $1
      FOR UPDATE
    `, [loanId]);

    if (!loanRes.rows.length) {
      throw new Error("Loan not found.");
    }

    const loan = loanRes.rows[0];

    // ❌ Cannot reject document after full processing
    if (loan.lifecycle_status === "FULLY_PROCESSED") {
      throw new Error(
        "Cannot reject document. Loan already fully processed."
      );
    }

    /* =====================================================
       🔒 Lock Document Row (Only allow PENDING)
    ===================================================== */
    const docRes = await client.query(`
      SELECT id, status
      FROM loan_session_documents
      WHERE id = $1
      AND session_id = (
        SELECT session_id FROM loans WHERE id = $2
      )
      AND COALESCE(status, 'PENDING') != 'APPROVED'
      FOR UPDATE
    `, [documentId, loanId]);

    if (!docRes.rows.length) {
      throw new Error(
        "Document not found or cannot be rejected in current state."
      );
    }

    const document = docRes.rows[0];

    if (document.status === "REJECTED") {
      throw new Error("Document is already rejected.");
    }

    /* =====================================================
       ❌ Mark Document Rejected
    ===================================================== */
    await client.query(`
      UPDATE loan_session_documents
      SET status = 'REJECTED',
          admin_comment = $2,
          reviewed_by = $3,
          reviewed_at = NOW()
      WHERE id = $1
    `, [documentId, cleanReason, approverId]);

    /* =====================================================
       🔥 Update Loan Lifecycle
    ===================================================== */
    await client.query(`
   UPDATE loans
SET lifecycle_status = 'BLOCKED_BY_DOCUMENT',
    updated_at = NOW()
WHERE id = $1
    `, [loanId]);

    /* =====================================================
       🔔 Notify Relationship Manager
    ===================================================== */
    if (loan.crm_staff_id) {
      await client.query(`
        INSERT INTO notifications
        (user_id, type, message, reference_id, created_at)
        VALUES (
          $1,
          'DOCUMENT_REJECTED',
          'A document was rejected. Please review and re-upload.',
          $2,
          NOW()
        )
      `, [loan.crm_staff_id, loanId]);
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document rejected successfully."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ rejectDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}


/* ======================================================
   APPROVE SINGLE DOCUMENT
====================================================== */
static async approveDocument({
  loanId,
  documentId,
  approverId
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK PENDING DOCUMENT
    ===================================================== */
    const docRes = await client.query(`
      SELECT lsd.id, lsd.status, l.lifecycle_status
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.id = $2
      AND lsd.status = 'PENDING'
      FOR UPDATE
    `, [loanId, documentId]);

    if (!docRes.rows.length) {
      throw new Error(
        "Document not found or cannot be approved in current state."
      );
    }

    const { lifecycle_status } = docRes.rows[0];

    /* =====================================================
       2️⃣ APPROVE DOCUMENT
    ===================================================== */
    await client.query(`
      UPDATE loan_session_documents
      SET status = 'APPROVED',
          admin_comment = NULL,
          reviewed_by = $2,
          reviewed_at = NOW()
      WHERE id = $1
    `, [documentId, approverId]);

    /* =====================================================
       3️⃣ CHECK IF ANY REJECTED DOCUMENTS REMAIN
    ===================================================== */
    const rejectedCheck = await client.query(`
      SELECT 1
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.status = 'REJECTED'
      LIMIT 1
    `, [loanId]);

    /* =====================================================
       4️⃣ RESTORE LIFECYCLE IF SAFE
    ===================================================== */
    if (
      lifecycle_status === "BLOCKED_BY_DOCUMENT" &&
      rejectedCheck.rows.length === 0
    ) {
      await client.query(`
        UPDATE loans
        SET lifecycle_status = 'INITIAL'
        WHERE id = $1
      `, [loanId]);
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document approved successfully."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ approveDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}



