static async getLoanSettings(client = null) {
  const db = client || pool;

  const res = await db.query(
    `SELECT loan_settings FROM system_settings LIMIT 1`
  );

  if (!res.rows.length) {
    throw new Error("Loan settings not found");
  }

  return res.rows[0].loan_settings || {};
}

