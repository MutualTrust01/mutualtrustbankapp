class LoanService {

  static normalizeName(name) {
  return name
    .toLowerCase()
    .replace(/[^a-z\s]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}
static cleanBase64(base64) {
  if (!base64) return undefined;
  return base64.replace(/^data:image\/\w+;base64,/, "");
}


static isNameMatch(bvnFullName, accountName) {
  const cleanBVN = LoanService.normalizeName(bvnFullName);
  const cleanAccount = LoanService.normalizeName(accountName);

  if (!cleanBVN || !cleanAccount) return false;

  // Exact match
  if (cleanBVN === cleanAccount) return true;

  const bvnParts = cleanBVN.split(" ").filter(Boolean);
  const accountParts = cleanAccount.split(" ").filter(Boolean);

  const matchedParts = bvnParts.filter((part) =>
    accountParts.includes(part)
  );

  // Relaxed rule:
  // pass if at least 2 name parts match
  // or one full name contains the other
  return (
    matchedParts.length >= 1 ||
    cleanBVN.includes(cleanAccount) ||
    cleanAccount.includes(cleanBVN)
  );
}


