/* ======================================================
   GET LOANS FOR LOGGED-IN RM (WITH DOCUMENTS)
====================================================== */
static async getLoansByRmId(rmId) {

const client = await pool.connect();

try {

  const loanConfig = await LoanService.getLoanSettings();
  const res = await client.query(`
    SELECT
      l.id,
      l.loan_code,
      l.status,
      l.product_code,
      l.created_at,
      l.updated_at,
      l.returned_at,
      l.rejected_at,
      l.approved_at,
      l.lifecycle_status,
      l.disbursement_status,

      ls.first_name,
      ls.last_name,

      la.answers,

      /* ================= DOCUMENTS ================= */
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'id', lsd.id,
            'doc_type', lsd.doc_type,
            'file_path', lsd.file_path,

            /* 🔥 derive filename from path safely */
            'file_name',
              CASE
                WHEN lsd.file_path IS NOT NULL THEN
                  split_part(
                    lsd.file_path,
                    '/',
                    array_length(string_to_array(lsd.file_path, '/'), 1)
                  )
                ELSE NULL
              END,

            'status', COALESCE(lsd.status, 'PENDING'),
            'admin_comment', lsd.admin_comment,
            'reviewed_at', lsd.reviewed_at,
            'uploaded_at', lsd.uploaded_at
          )
        ) FILTER (WHERE lsd.id IS NOT NULL),
        '[]'
      ) AS documents,

      /* ================= APPROVAL HISTORY ================= */
      COALESCE(
        json_agg(
          DISTINCT jsonb_build_object(
            'approval_id', lap.id,
            'approval_status', lap.approval_status,
            'approval_level', lap.approval_level,
            'approval_reason', lap.approval_reason,
            'created_at', lap.created_at,
            'approver_name',
              CONCAT(
                INITCAP(u.first_name),
                ' ',
                INITCAP(u.last_name)
              )
          )
        ) FILTER (WHERE lap.id IS NOT NULL),
        '[]'
      ) AS approval_history,

      COALESCE(
        (
          SELECT MAX(approval_level)
          FROM loan_approvals
          WHERE loan_id = l.id
          AND approval_status = 'APPROVED'
        ),
        0
      ) AS current_level

    FROM loans l

    JOIN loan_sessions ls
      ON ls.id = l.session_id

    LEFT JOIN loan_answers la
      ON la.loan_id = l.id

    LEFT JOIN loan_session_documents lsd
      ON lsd.session_id = l.session_id

    LEFT JOIN loan_approvals lap
      ON lap.loan_id = l.id

    LEFT JOIN users u
      ON u.id = lap.approver_id

    WHERE l.crm_staff_id = $1

    GROUP BY
      l.id,
      ls.id,
      la.answers

    ORDER BY l.created_at DESC
  `, [rmId]);

  const loans = res.rows.map(row => {

    const productConfig =
      loanConfig.productApprovals?.[row.product_code] || {};

    const flow = productConfig.flow || [];
    const totalLevels = flow.length;
    const currentLevel = Number(row.current_level || 0);

    const isFullyApproved =
      totalLevels > 0 &&
      currentLevel >= totalLevels;

    const nextRoleId =
      !isFullyApproved
        ? flow[currentLevel]
        : null;

    const answers =
      typeof row.answers === "string"
        ? JSON.parse(row.answers)
        : row.answers || {};

    const amountKey = Object.keys(answers)
      .find(k => k.toLowerCase().includes("amount"));

    const approvalPercentage =
      totalLevels > 0
        ? Math.round((currentLevel / totalLevels) * 100)
        : 0;

    const progressLabel =
      `${currentLevel}/${totalLevels}`;

    const approvalFlow = flow.map((roleId, index) => {
      const role = loanConfig.roles?.find(
        r => String(r.id) === String(roleId)
      );

      return {
        level: index + 1,
        role_id: roleId,
        role_name: role?.name || `Level ${index + 1}`,
        completed: currentLevel > index,
        current: currentLevel === index
      };
    });

    let slaDeadline = null;
    let slaExpired = false;

    if (!isFullyApproved && row.status === "PENDING_REVIEW") {

      const slaHours =
        productConfig.slaHoursPerLevel || 24;

      const approvedHistory =
        Array.isArray(row.approval_history)
          ? row.approval_history
              .filter(a => a.approval_status === "APPROVED")
              .sort(
                (a, b) =>
                  new Date(a.created_at) -
                  new Date(b.created_at)
              )
          : [];

      const lastApproval =
        approvedHistory.length
          ? approvedHistory[approvedHistory.length - 1]
          : null;

      const baseTime =
        lastApproval?.created_at || row.created_at;

      const deadline = new Date(baseTime);
      deadline.setHours(deadline.getHours() + slaHours);

      slaDeadline = deadline;
      slaExpired = new Date() > deadline;
    }

    let pendingWith = null;

    if (row.status === "PENDING_REVIEW" && !isFullyApproved) {

      const role = loanConfig.roles?.find(
        r => String(r.id) === String(nextRoleId)
      );

      pendingWith =
        role?.name ||
        `Level ${currentLevel + 1}`;
    }

    if (row.status === "RETURNED") {
      pendingWith = "Relationship Manager";
    }

    if (row.status === "REJECTED") {
      pendingWith = null;
    }

    if (isFullyApproved &&
        row.disbursement_status !== "COMPLETED") {
      pendingWith = "Disbursement";
    }

    if (row.disbursement_status === "COMPLETED") {
      pendingWith = null;
    }

    return {
      id: row.id,
      loan_code: row.loan_code,
      status: row.status,
      lifecycle_status: row.lifecycle_status,
      disbursement_status: row.disbursement_status,
      product_code: row.product_code,

      product_name:
        loanConfig.productMeta?.[row.product_code]?.name ||
        row.product_code,

      created_at: row.created_at,
      updated_at: row.updated_at,
      approved_at: row.approved_at,
      rejected_at: row.rejected_at,
      returned_at: row.returned_at,

      approval_history:
        Array.isArray(row.approval_history)
          ? row.approval_history.sort(
              (a, b) =>
                new Date(a.created_at) -
                new Date(b.created_at)
            )
          : [],

      documents:
        Array.isArray(row.documents)
          ? row.documents
          : [],

      total_levels: totalLevels,
      current_level: currentLevel,
      next_level: nextRoleId,
      is_fully_approved: isFullyApproved,
      approval_percentage: approvalPercentage,
      approval_progress_label: progressLabel,
      approval_flow: approvalFlow,
      pending_with: pendingWith,

      sla_deadline: slaDeadline,
      sla_expired: slaExpired,

      customer_name:
        `${row.first_name} ${row.last_name}`,

      amount:
        amountKey ? Number(answers[amountKey]) : 0
    };
  });

 return {
  success: true,
  data: loans
};

} catch (err) {

  console.error("❌ getLoansByRmId error:", err.message);
  throw err;

} finally {

  client.release();

}
}



static async logLoanStatusChange(
  { loanId, oldStatus, newStatus, changedBy, reason = null },
  client
) {
  await client.query(
    `
    INSERT INTO loan_status_history
    (loan_id, old_status, new_status, changed_by, change_reason)
    VALUES ($1, $2, $3, $4, $5)
    `,
    [loanId, oldStatus, newStatus, changedBy, reason]
  );
}



/* ======================================================
   GET LOAN TRANSFERS (WITH FILTERS)
====================================================== */
static async getLoanTransfers({
  status = null,
  manualFunding = false,
  fromDate = null,
  toDate = null
} = {}) {

const client = await pool.connect();

try {

  const values = [];
  let whereConditions = [`lfe.event_type = 'TRANSFER'`];

  if (status) {
    values.push(status);
    whereConditions.push(`lfe.status = $${values.length}`);
  }

  if (manualFunding === true) {
    whereConditions.push(`l.disbursement_status = 'AWAITING_MANUAL_FUNDING'`);
  }

  if (fromDate) {
    values.push(fromDate);
    whereConditions.push(`lfe.created_at >= $${values.length}`);
  }

  if (toDate) {
    values.push(toDate);
    whereConditions.push(`lfe.created_at <= $${values.length}`);
  }

  const whereClause =
    whereConditions.length
      ? `WHERE ${whereConditions.join(" AND ")}`
      : "";

  const res = await client.query(`
    SELECT
      lfe.id,
      lfe.loan_id,
      lfe.reference,
      lfe.amount,
      lfe.status,
      lfe.created_at,
      lfe.core_response,
      l.loan_code,
      l.product_code,
      l.disbursement_status,
      l.lifecycle_status,
      CONCAT(ls.first_name, ' ', ls.last_name) AS customer_name
    FROM loan_financial_events lfe
    JOIN loans l ON l.id = lfe.loan_id
    JOIN loan_sessions ls ON ls.id = l.session_id
    ${whereClause}
    ORDER BY lfe.created_at DESC
  `, values);

  return {
    success: true,
    count: res.rows.length,
    data: res.rows
  };

} finally {
  client.release();
}
}
