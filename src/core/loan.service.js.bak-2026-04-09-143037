   RE-UPLOAD DOCUMENT (RM SIDE)
   Only allowed when loan status = RETURNED
====================================================== */
static async reuploadDocument({
  documentId,
  filePath,
  fileName
}) {

  const client = await pool.connect();

  try {
    await client.query("BEGIN");

    /* =====================================================
       1️⃣ LOCK DOCUMENT + LOAN
    ===================================================== */
    const docRes = await client.query(`
      SELECT 
        lsd.id,
        lsd.status AS document_status,
        l.id AS loan_id,
        l.lifecycle_status,
        l.status AS loan_status
      FROM loan_session_documents lsd
      JOIN loans l 
        ON l.session_id = lsd.session_id
      WHERE lsd.id = $1
      FOR UPDATE
    `, [documentId]);

    if (!docRes.rows.length) {
      throw new Error("Document not found.");
    }

    const document = docRes.rows[0];

    /* =====================================================
       2️⃣ STRICT BUSINESS RULE VALIDATION
    ===================================================== */

    // ❌ Prevent after full processing
    if (document.lifecycle_status === "FULLY_PROCESSED") {
      throw new Error(
        "Cannot re-upload document. Loan already fully processed."
      );
    }

    // 🔒 Only allow when loan is RETURNED
    if (document.loan_status !== "RETURNED") {
      throw new Error(
        "Documents can only be replaced when loan is returned."
      );
    }

    // 🔒 Only allow replacing rejected documents
    if (document.document_status !== "REJECTED") {
      throw new Error(
        "Only rejected documents can be replaced."
      );
    }

    /* =====================================================
       3️⃣ UPDATE DOCUMENT (Reset to PENDING)
    ===================================================== */
    await client.query(`
    UPDATE loan_session_documents
SET file_path = $2,
    status = 'PENDING',
    admin_comment = NULL,
    reviewed_by = NULL,
    reviewed_at = NULL,
    uploaded_at = NOW()
WHERE id = $1
    `, [documentId, filePath]);

    /* =====================================================
       4️⃣ CHECK IF ANY REJECTED DOCS REMAIN
    ===================================================== */
    const rejectedCheck = await client.query(`
      SELECT 1
      FROM loan_session_documents lsd
      JOIN loans l ON l.session_id = lsd.session_id
      WHERE l.id = $1
      AND lsd.status = 'REJECTED'
      LIMIT 1
    `, [document.loan_id]);

    /* =====================================================
       5️⃣ IF ALL DOCUMENTS FIXED → RESTORE LOAN
    ===================================================== */
    if (rejectedCheck.rows.length === 0) {

      // 🔥 Get current status for audit log
      const statusRes = await client.query(
        `SELECT status FROM loans WHERE id = $1`,
        [document.loan_id]
      );

      const oldStatus = statusRes.rows[0]?.status;

      // 🔥 Move loan back into approval flow
      await client.query(`
        UPDATE loans
        SET lifecycle_status = 'INITIAL',
            status = 'PENDING_REVIEW',
            updated_at = NOW()
        WHERE id = $1
      `, [document.loan_id]);

      // 🔥 Log status change
      await LoanService.logLoanStatusChange(
        {
          loanId: document.loan_id,
          oldStatus,
          newStatus: "PENDING_REVIEW",
          changedBy: null, // RM action (optional: pass RM ID if available)
          reason: "All rejected documents replaced"
        },
        client
      );
    }

    await client.query("COMMIT");

    return {
      success: true,
      message: "Document replaced and resubmitted for review."
    };

  } catch (err) {

    await client.query("ROLLBACK");
    console.error("❌ reuploadDocument error:", err.message);
    throw err;

  } finally {
    client.release();
  }
}

