generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                               Int                   @id @default(autoincrement())
  firstName                        String?               @map("first_name") @db.VarChar(100)
  lastName                         String?               @map("last_name") @db.VarChar(100)
  email                            String                @unique @db.VarChar(150)
  phoneNumber                      String?               @map("phone_number") @db.VarChar(20)
  gender                           String?               @db.VarChar(10)
  department                       String?               @db.VarChar(100)
  canApprove                       Boolean?              @default(false) @map("can_approve")
  password                         String                @db.VarChar(200)
  createdAt                        DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  username                         String?               @unique @db.VarChar(50)
  status                           String?               @default("Active") @db.VarChar(20)
  otp                              String?
  otpExpires                       DateTime?             @map("otp_expires") @db.Timestamptz(6)
  failedAttempts                   Int?                  @default(0) @map("failed_attempts")
  lastFailedLogin                  DateTime?             @map("last_failed_login") @db.Timestamp(6)
  loginStatus                      String                @default("Active") @map("login_status") @db.VarChar(20)
  resetOtpHash                     String?               @map("reset_otp_hash")
  resetOtpExpires                  DateTime?             @map("reset_otp_expires") @db.Timestamp(6)
  resetVerified                    Boolean?              @default(false) @map("reset_verified")
  roleId                           Int?                  @map("role_id")
  lastPasswordReset                DateTime?             @map("last_password_reset") @db.Timestamp(6)
  mustChangePassword               Boolean?              @default(false) @map("must_change_password")
  lastPasswordChange               DateTime?             @default(now()) @map("last_password_change") @db.Timestamp(6)
  lastPasswordChangedAt            DateTime?             @map("last_password_changed_at") @db.Timestamp(6)
  profilePicture                   String?               @map("profile_picture")
  passwordChangeOtpHash            String?               @map("password_change_otp_hash")
  passwordChangeOtpExpires         DateTime?             @map("password_change_otp_expires") @db.Timestamptz(6)
  passwordChangeOtpAttempts        Int?                  @default(0) @map("password_change_otp_attempts")
  signaturePath                    String?               @map("signature_path")
  signatureHash                    String?               @map("signature_hash")
  canAccessHrmCrm                  Boolean?              @map("can_access_hrm_crm")
  canAccessAdmin                   Boolean?              @map("can_access_admin")
  device_locked                    Boolean?
  staffStatus                      String?               @map("staff_status")
  registeredAt                     DateTime?             @map("registered_at")
  device_id                        String?
  staffRole                        String?               @default("Officer") @map("staff_role") @db.VarChar(100)
  team                             String?               @default("Back Office") @db.VarChar(50)
  dateOfBirth                      DateTime?             @map("date_of_birth") @db.Date
  dateOfEmployment                 DateTime?             @map("date_of_employment") @db.Date
  grade                            String?               @db.VarChar(50)
  designation                      String?               @db.VarChar(100)
  branch                           String?               @db.VarChar(100)
  rejection_reason                 String?
  rejected_at                      DateTime?             @db.Timestamp(6)
  core_account_officer_status      String?               @default("AWAITING_CREATION") @db.VarChar(50)
  core_account_officer_marked_by   Int?
  core_account_officer_marked_at   DateTime?             @db.Timestamp(6)
  core_account_officer_verified_at DateTime?             @db.Timestamp(6)
  locked_until                     DateTime?             @db.Timestamp(6)
  pushSubscription                 Json?                 @map("push_subscription")
  approval_requests                approval_requests[]
  approval_steps                   approval_steps[]
  role_approvals                   role_approvals[]
  rolesCreated                     roles[]               @relation("roles_created_byTousers")
  staff_sessions                   staff_sessions[]
  staff_verifications              staff_verifications[]
  role                             roles?                @relation("users_role_idToroles", fields: [roleId], references: [id], onDelete: Restrict, map: "fk_users_role")

  @@map("users")
}

model accounts {
  id                   Int        @id @default(autoincrement())
  customer_id          String?    @db.VarChar(20)
  account_number       String?    @unique @db.VarChar(20)
  account_type         String?    @db.VarChar(30)
  status               String?    @db.VarChar(20)
  created_at           DateTime?  @default(now()) @db.Timestamp(6)
  single_limit         Decimal?   @default(0) @db.Decimal
  daily_limit          Decimal?   @default(0) @db.Decimal
  core_account_number  String?    @db.VarChar(30)
  nuban                String?    @db.VarChar(10)
  available_balance    Decimal?   @db.Decimal
  ledger_balance       Decimal?   @db.Decimal
  withdrawable_balance Decimal?   @db.Decimal
  last_core_sync       DateTime?  @db.Timestamp(6)
  customers            customers? @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: NoAction)
}

model app_settings {
  id            Int       @id @default(autoincrement())
  setting_key   String    @unique @db.VarChar(100)
  setting_value String
  description   String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
}

model approval_logs {
  id          Int       @id @default(autoincrement())
  request_id  Int?
  approver_id Int?
  action      String?   @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  comment     String?

  @@unique([request_id, approver_id, action], map: "uniq_approval_log")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model approval_requests {
  id                 Int              @id @default(autoincrement())
  request_type       String?
  entity_id          Int?
  initiated_by       Int
  required_approvals Int?
  current_approvals  Int?             @default(0)
  status             String?          @default("Pending")
  created_at         DateTime?        @default(now()) @db.Timestamp(6)
  approved_count     Int?             @default(0)
  request_ref_id     Int
  can_resubmit       Boolean          @default(false)
  data               Json?
  users              User             @relation(fields: [initiated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approval_steps     approval_steps[]
}

model approval_steps {
  id                  Int                @id @default(autoincrement())
  approval_request_id Int?
  role                String?
  approved_by         Int?
  status              String?            @default("Pending")
  approved_at         DateTime?          @db.Timestamp(6)
  approval_requests   approval_requests? @relation(fields: [approval_request_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               User?              @relation(fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model audit_logs {
  id          Int       @id @default(autoincrement())
  actor_id    Int?
  actor_type  String?   @db.VarChar(20)
  action      String    @db.VarChar(200)
  status      String    @default("INFO") @db.VarChar(20)
  description String?
  target_id   Int?
  target_type String?   @db.VarChar(50)
  ip_address  String?   @db.VarChar(50)
  user_agent  String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model chat_messages {
  id           Int        @id @default(autoincrement())
  room_id      String
  sender       String     @db.VarChar(20)
  message      String
  created_at   DateTime?  @default(now()) @db.Timestamp(6)
  read         Boolean?   @default(false)
  delivered    Boolean?   @default(false)
  read_at      DateTime?  @db.Timestamp(6)
  delivered_at DateTime?  @db.Timestamp(6)
  chat_rooms   chat_rooms @relation(fields: [room_id], references: [room_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_chat_room_text")
}

model chat_rooms {
  id             Int             @id @default(autoincrement())
  customer_id    BigInt?
  admin_id       Int?
  status         String          @default("BOT") @db.VarChar(20)
  created_at     DateTime?       @default(now()) @db.Timestamp(6)
  customer_name  String?
  room_id        String?         @unique(map: "chat_rooms_room_id_idx")
  account_number String?
  chat_messages  chat_messages[]

  @@index([status], map: "idx_chat_rooms_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chats {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id       String?
  status            String?   @default("bot") @db.VarChar(20)
  assigned_admin_id Int?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
}

model complaint_history {
  id           Int       @id @default(autoincrement())
  complaint_id Int
  action       String    @db.VarChar(50)
  message      String?
  actor_id     Int?
  actor_role   String?   @db.VarChar(20)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

model complaints {
  id                Int       @id @default(autoincrement())
  reference_id      String    @unique @db.VarChar(30)
  customer_id       String?   @db.VarChar(50)
  name              String?   @db.VarChar(100)
  email             String?   @db.VarChar(100)
  phone             String?   @db.VarChar(20)
  category          String?   @db.VarChar(50)
  subject           String?   @db.VarChar(150)
  description       String?
  attachment_url    String?
  preferred_contact String?   @db.VarChar(20)
  status            String?   @default("Submitted") @db.VarChar(20)
  assigned_admin    String?   @db.VarChar(50)
  admin_message     String?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)
}

model customer_documents {
  id            Int       @id @default(autoincrement())
  customer_id   String    @db.VarChar(20)
  document_type String    @db.VarChar(50)
  file_url      String
  uploaded_by   String?   @db.VarChar(50)
  uploaded_at   DateTime? @default(now()) @db.Timestamp(6)
  customers     customers @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_customer_docs")

  @@index([document_type], map: "idx_customer_documents_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model customers {
  customer_id        String               @id @db.VarChar(20)
  first_name         String?              @db.VarChar(60)
  last_name          String?              @db.VarChar(60)
  email              String?              @db.VarChar(100)
  phone              String?              @db.VarChar(20)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  username           String?              @db.VarChar(60)
  bvn                String?              @unique(map: "customers_bvn_unique") @db.VarChar(20)
  nin                String?              @unique(map: "customers_nin_unique") @db.VarChar(20)
  password_hash      String?
  pin_hash           String?
  status             String?              @default("Active") @db.VarChar(20)
  accounts           accounts[]
  customer_documents customer_documents[]
}

model fd_certificate_otps {
  id                      Int                      @id @default(autoincrement())
  request_id              Int?
  otp                     String?                  @db.VarChar(6)
  expires_at              DateTime?                @db.Timestamp(6)
  verified                Boolean?                 @default(false)
  fd_certificate_requests fd_certificate_requests? @relation(fields: [request_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model fd_certificate_requests {
  id                  Int                   @id @default(autoincrement())
  fd_account          String                @db.VarChar(30)
  request_type        String?               @db.VarChar(20)
  requested_by        Int?
  amount              Decimal?              @db.Decimal(15, 2)
  status              String?               @default("pending") @db.VarChar(20)
  approval_level      Int?                  @default(1)
  approved_by         Int?
  approved_at         DateTime?             @db.Timestamp(6)
  otp_required        Boolean?              @default(false)
  otp_verified        Boolean?              @default(false)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  fd_certificate_otps fd_certificate_otps[]
}

model fd_certificates {
  id                 Int       @id @default(autoincrement())
  fd_account         String    @db.VarChar(30)
  certificate_no     String    @unique @db.VarChar(50)
  generated_by       Int?
  generated_at       DateTime? @db.Timestamp(6)
  regeneration_count Int?      @default(0)
  pdf_path           String?
  status             String?   @default("active") @db.VarChar(20)
}

model fixed_deposit_approvals {
  id               BigInt         @id @default(autoincrement())
  fixed_deposit_id BigInt
  approval_level   Int
  approver_user_id BigInt
  status           String?        @default("Pending") @db.VarChar(20)
  approved_at      DateTime?      @db.Timestamp(6)
  remarks          String?
  created_at       DateTime?      @default(now()) @db.Timestamp(6)
  fixed_deposits   fixed_deposits @relation(fields: [fixed_deposit_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_fd_approval")
}

model fixed_deposits {
  id                         BigInt                    @id @default(autoincrement())
  customer_id                String                    @db.VarChar(20)
  customer_name              String?                   @db.VarChar(255)
  fd_account_number          String                    @unique @db.VarChar(30)
  liquidation_account        String?                   @db.VarChar(30)
  product_code               String?                   @db.VarChar(20)
  product_name               String?                   @db.VarChar(255)
  principal_amount           Decimal?                  @db.Decimal(18, 2)
  interest_rate              Decimal?                  @db.Decimal(5, 2)
  tenor_days                 Int?
  should_rollover            Boolean?                  @default(false)
  apply_interest_on_rollover Boolean?                  @default(false)
  status                     String?                   @default("Active") @db.VarChar(30)
  approval_status            String?                   @default("Pending") @db.VarChar(20)
  created_by                 String?                   @db.VarChar(50)
  created_at                 DateTime?                 @default(now()) @db.Timestamp(6)
  fixed_deposit_approvals    fixed_deposit_approvals[]
}

model permissions {
  id               Int                @id @default(autoincrement())
  code             String             @unique @db.VarChar(100)
  description      String?
  role_permissions role_permissions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model role_approvals {
  id          Int       @id @default(autoincrement())
  role_id     Int?
  approved_by Int?
  approved_at DateTime? @default(now()) @db.Timestamp(6)
  reason      String?
  action      String?   @db.VarChar(20)
  users       User?     @relation(fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles       roles?    @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([role_id, approved_by])
  @@unique([role_id, approved_by], map: "unique_role_approver")
}

model role_permissions {
  id            Int         @id @default(autoincrement())
  role          String      @db.VarChar(50)
  permission_id Int
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_permission")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model roles {
  id                            Int              @id @default(autoincrement())
  name                          String           @db.VarChar(100)
  permissions                   String[]
  users_assigned                Int?             @default(0)
  status                        String?          @default("Pending") @db.VarChar(20)
  description                   String?
  created_on                    DateTime?        @default(now()) @db.Date
  approved_count                Int?             @default(0)
  required_approvals            Int              @default(1)
  created_by                    Int
  role_approvals                role_approvals[]
  users_roles_created_byTousers User             @relation("roles_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_roles_created_by")
  users_users_role_idToroles    User[]           @relation("users_role_idToroles")
}

model system_logs {
  id         Int       @id @default(autoincrement())
  event_type String?   @db.VarChar(100)
  message    String?
  details    Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model system_settings {
  id                            Int       @id @default(autoincrement())
  default_single_limit          Decimal?  @db.Decimal
  default_daily_limit           Decimal?  @db.Decimal
  customer_2fa_enabled          Boolean?
  admin_2fa_enabled             Boolean?
  password_policy               String?   @db.VarChar(20)
  email_notifications           Boolean?
  push_notifications            Boolean?
  approval_settings             Json
  updated_at                    DateTime? @default(now()) @db.Timestamp(6)
  system_access                 Json?     @default("{\"mobileLoginEnabled\": true, \"internetBankingLoginEnabled\": true}")
  contact_details               Json?     @default("{\"contactEmail\": \"\", \"contactPhones\": \"\", \"contactAddress\": \"\"}")
  onboarding_config             Json?     @default("{}")
  privacy_settings              Json?     @default("{}")
  session_config                Json?     @default("{\"adminTimeout\": 15, \"mobileTimeout\": 10, \"internetBankingTimeout\": 10}")
  admin_password_expiry_days    Int?      @default(90)
  customer_password_expiry_days Int?      @default(180)
  session_version               Int       @default(1)
  tier_limits                   Json?
  fixed_deposit_settings        Json?
  loan_settings                 Json      @default("{\"allowedProducts\": [], \"productApprovals\": {}, \"bvnVerificationMode\": \"BASIC\"}")
}

model transactions {
  id              BigInt    @id @default(autoincrement())
  transaction_ref String    @unique @db.VarChar(100)
  account_number  String    @db.VarChar(30)
  txn_date        DateTime? @db.Date
  value_date      DateTime? @db.Date
  debit           Decimal?  @default(0) @db.Decimal(18, 2)
  credit          Decimal?  @default(0) @db.Decimal(18, 2)
  balance_after   Decimal?  @db.Decimal(18, 2)
  narration       String?
  teller          String?   @db.VarChar(50)
  source          String?   @db.VarChar(50)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model wallet_transactions {
  id         Int       @id @default(autoincrement())
  user_id    Int
  reference  String    @unique @db.VarChar(100)
  amount     Decimal   @db.Decimal(14, 2)
  type       String?   @db.VarChar(20)
  source     String?   @default("paystack") @db.VarChar(30)
  status     String?   @default("success") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model wallets {
  id         Int       @id @default(autoincrement())
  user_id    Int       @unique
  balance    Decimal?  @default(0) @db.Decimal(14, 2)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model direct_debit_mandates {
  id                 Int       @id @default(autoincrement())
  customer_email     String
  reference          String    @unique
  callback_token     String?   @unique
  authorization_code String?
  bank               String?
  status             String?
  initiated_by       String?
  account_number     String?
  account_name       String?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  loan_id            String?   @db.Uuid
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  loan               loans?    @relation(fields: [loan_id], references: [id])
}

model PayslipUpload {
  id           Int             @id @default(autoincrement())
  upload_month String          @db.VarChar(20)
  uploaded_by  String          @db.VarChar(100)
  uploaded_at  DateTime        @default(now())
  status       String          @db.VarChar(10)
  record_count Int
  records      PayslipRecord[]

  @@map("payslip_uploads")
}

model PayslipRecord {
  id           Int            @id @default(autoincrement())
  ippis_number String
  data         Json
  created_at   DateTime       @default(now())
  upload_id    Int?
  upload_month String?        @db.VarChar(7)
  upload       PayslipUpload? @relation(fields: [upload_id], references: [id], onDelete: Cascade)

  @@index([ippis_number, upload_month], map: "idx_payslip_ippis_month")
  @@index([ippis_number])
  @@map("payslip_records")
}

model PayslipCustomer {
  id             Int      @id @default(autoincrement())
  ippis_number   String
  account_number String
  bank_name      String?
  salary         Float?
  net_pay        Float?
  upload_month   String?  @db.VarChar(7)
  raw_data       Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([ippis_number, account_number])
  @@index([ippis_number])
  @@map("payslip_customers")
}

model user_sessions {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "idx_user_sessions_expire")
  @@map("user_sessions")
  @@ignore
}

model loans {
  id                              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_code                       String                  @db.VarChar(30)
  session_id                      String                  @unique(map: "unique_session_loan") @db.Uuid
  crm_staff_code                  String?                 @db.VarChar(20)
  status                          String?                 @default("UNDER_REVIEW") @db.VarChar(30)
  created_at                      DateTime?               @default(now()) @db.Timestamp(6)
  crm_staff_id                    Int?
  product_code                    String?
  core_status                     String?                 @default("NOT_CREATED") @db.VarChar
  disbursement_status             String?                 @default("NOT_DISBURSED") @db.VarChar
  disbursed_at                    DateTime?               @db.Timestamp(6)
  approved_at                     DateTime?               @db.Timestamp(6)
  core_created_at                 DateTime?               @db.Timestamp(6)
  rejected_at                     DateTime?               @db.Timestamp(6)
  direct_debit_status             String?                 @db.VarChar(20)
  direct_debit_required           Boolean?                @default(false)
  core_loan_account_number        String?                 @db.VarChar(50)
  loan_account_opening_refid      String?                 @db.VarChar(100)
  settlement_account_auto_created Boolean?                @default(false)
  settlement_account_number       String?                 @unique(map: "unique_settlement_account") @db.VarChar(50)
  account_number                  String?                 @db.VarChar(20)
  salary_account_number           String?                 @db.VarChar(20)
  transfer_tracking_ref           String?                 @db.VarChar(100)
  salary_account_name             String?                 @db.VarChar(255)
  mandate_sent                    Boolean?                @default(false)
  mandate_reference               String?                 @db.VarChar(150)
  mandate_sent_at                 DateTime?               @db.Timestamp(6)
  lifecycle_status                String?                 @default("INITIAL") @db.VarChar(30)
  updated_at                      DateTime                @default(now()) @db.Timestamp(6)
  pending_with                    String?                 @db.VarChar(50)
  returned_at                     DateTime?               @db.Timestamp(6)
  current_approval_level          Int?                    @default(0)
  current_role_id                 Int?
  direct_debit_mandates           direct_debit_mandates[]
  loan_repayments                 loan_repayments[]

  @@index([session_id])
  @@index([status])
  @@index([session_id], map: "idx_loans_session_id")
}

model loan_repayments {
  id         Int      @id @default(autoincrement())
  amount     Decimal  @db.Decimal(18, 2)
  due_date   DateTime @db.Date
  status     String   @default("PENDING")
  reference  String?
  created_at DateTime @default(now()) @db.Timestamp(6)
  email      String
  loan_id    String   @db.Uuid
  loan       loans    @relation(fields: [loan_id], references: [id])
}

model loan_answers {
  id      Int    @id @default(autoincrement())
  loan_id String @db.Uuid
  answers Json
}

model loan_approval_files {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id     String?   @db.Uuid
  approval_id Int?
  file_name   String?
